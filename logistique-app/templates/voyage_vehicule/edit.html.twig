{% extends 'base.html.twig' %}

{% block title %}Modifier le trajet - {{ voyage_vehicule.destination.libelle }}{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Modifier le trajet: {{ voyage_vehicule.destination.libelle }}</h3>
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ path('app_voyage_vehicule_edit', {'id': voyage_vehicule.id}) }}">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="destination">Destination</label>
                                        <select class="form-select" id="destination" name="destination" required>
                                            <option value="">Sélectionner une destination</option>
                                            {% for destination in destinations %}
                                                <option value="{{ destination.id }}" {{ voyage_vehicule.destination.id == destination.id ? 'selected' : '' }}>
                                                    {{ destination.libelle }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <div class="mb-3">
                                        <label class="form-label" for="commentaire">Commentaire</label>
                                        <textarea class="form-control" id="commentaire" name="commentaire" rows="3">{{ voyage_vehicule.commentaire }}</textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i> Enregistrer
                                </button>
                                <a href="{{ path('app_voyage_show', {'id': voyage.id}) }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i> Retour au voyage
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}