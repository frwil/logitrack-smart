{% extends 'base.html.twig' %}

{% block title %}Nouvelle Région{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Créer une nouvelle Région</h3>
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ path('app_region_new') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('create_region') }}">
                            <div class="mb-3">
                                <label class="form-label" for="nom">Nom de la Région</label>
                                <input type="text" class="form-control" name="nom" id="nom" required>
                            </div>
                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                            <a href="{{ path('app_region_index') }}" class="btn btn-secondary">Annuler</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}