{% extends 'base.html.twig' %}

{% block title %}Documents du véhicule {{ vehicule.immatriculationVehicule }}{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Documents du véhicule {{ vehicule.immatriculationVehicule }}</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_vehicule_index') }}" class="btn btn-secondary me-2">
                                <i class="fas fa-arrow-left me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Retour aux véhicules</span>
                            </a>
                            <a href="{{ path('app_document_vehicule_new', {'id': vehicule.id}) }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Ajouter un document</span>
                                <i class="fas fa-plus d-sm-none"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        {% if documents|length > 0 %}
                        <div class="table-responsive">
                            <table id="documents-table" class="table card-table table-vcenter text-nowrap datatable">
                                <thead>
                                    <tr>
                                        <th>Type de document</th>
                                        <th>Référence</th>
                                        <th>Date d'expiration</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for document in documents %}
                                    <tr>
                                        <td>{{ document.typeDocument.nom }}</td>
                                        <td>{{ document.reference }}</td>
                                        <td>{{ document.dateExpiration|date('d/m/Y') }}</td>
                                        <td>
                                            {% if document.isActive %}
                                            <span class="badge text-bg-success">Actif</span>
                                            {% else %}
                                            <span class="badge text-bg-secondary">Inactif</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="{{ path('app_document_vehicule_show', {'id': vehicule.id, 'documentId': document.id}) }}" 
                                                   class="btn btn-icon btn-sm" title="Voir">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('app_document_vehicule_edit', {'id': vehicule.id, 'documentId': document.id}) }}" 
                                                   class="btn btn-icon btn-sm" title="Modifier">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form method="post" 
                                                      action="{{ path('app_document_vehicule_toggle_active', {'id': vehicule.id, 'documentId': document.id}) }}" 
                                                      class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle-active' ~ document.id) }}">
                                                    <button type="submit" class="btn btn-icon btn-sm {{ document.isActive ? 'btn-secondary' : 'btn-success' }}" 
                                                            title="{{ document.isActive ? 'Désactiver' : 'Activer' }}">
                                                        <i class="fas {{ document.isActive ? 'fa-toggle-on' : 'fa-toggle-off' }}"></i>
                                                    </button>
                                                </form>
                                                <form method="post" 
                                                      action="{{ path('app_document_vehicule_delete', {'id': vehicule.id, 'documentId': document.id}) }}" 
                                                      class="d-inline" 
                                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce document ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document.id) }}">
                                                    <button type="submit" class="btn btn-icon btn-sm text-danger" title="Supprimer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% else %}
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Aucun document n'a été ajouté à ce véhicule.
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function () {
        $('#documents-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            },
            order: [[0, 'asc']],
            responsive: true,
            columnDefs: [
                { responsivePriority: 1, targets: 0 },
                { responsivePriority: 2, targets: -1 }
            ]
        });
    });
</script>
{% endblock %}