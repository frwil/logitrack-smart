{# templates/user/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier l'Utilisateur{% endblock %}

{% block body %}

<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Modifier l'utilisateur</h3>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="row">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Email</label>
                                            <input type="text" class="form-control" value="{{ user.email }}" readonly>
                                            <small class="form-text text-muted">L'email ne peut pas être
                                                modifié.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="telephone" class="form-label">Téléphone</label>
                                            <input type="text" class="form-control" id="telephone" name="telephone"
                                                value="{{ user.telephone }}">
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="nom" class="form-label">Nom</label>
                                            <input type="text" class="form-control" id="nom" name="nom"
                                                value="{{ user.nom }}" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="prenom" class="form-label">Prénom</label>
                                            <input type="text" class="form-control" id="prenom" name="prenom"
                                                value="{{ user.prenom }}" required>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="region" class="form-label">Région</label>
                                            <select class="form-control" id="region" name="region">
                                                <option value="">Sélectionner une région</option>
                                                {% for region in regions %}
                                                <option value="{{ region.id }}" {{ user.region and
                                                    user.region.id==region.id ? 'selected' : '' }}>{{ region.nom }}
                                                </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="isActive"
                                                    name="isActive" {{ user.isActive ? 'checked' : '' }}>
                                                <label class="form-check-label" for="isActive">Utilisateur actif</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Rôles</label>
                                    <div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="checkbox" id="role_user"
                                                name="roles[]" value="ROLE_USER" {{ 'ROLE_USER' in user.roles
                                                ? 'checked' : '' }}>
                                            <label class="form-check-label" for="role_user">Utilisateur</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="checkbox" id="role_admin"
                                                name="roles[]" value="ROLE_ADMIN" {{ 'ROLE_ADMIN' in user.roles
                                                ? 'checked' : '' }}>
                                            <label class="form-check-label" for="role_admin">Administrateur</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="checkbox" id="role_super_admin"
                                                name="roles[]" value="ROLE_SUPER_ADMIN" {{ 'ROLE_SUPER_ADMIN' in
                                                user.roles ? 'checked' : '' }} {{ app.user.id==user.id ? 'disabled' : ''
                                                }}>
                                            <label class="form-check-label" for="role_super_admin">Super Admin</label>
                                        </div>
                                    </div>
                                </div>

                                {# Section des permissions #}
                                <div class="mb-4">
                                    <label class="form-label">Permissions</label>
                                    <div class="alert alert-info">
                                        <small>
                                            <i class="fas fa-info-circle"></i> Les Super Administrateurs ont
                                            automatiquement tous les droits.
                                            Les permissions définies ici seront ignorées pour les Super Admins.
                                        </small>
                                    </div>

                                    <div class="accordion" id="permissionsAccordion">
                                        {% for module, actions in {
                                        'vehicule': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'affectation': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'maintenance': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'reparation': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'vidange_vehicule': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'voyage': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'voyage_vehicule': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'document': ['view', 'create', 'update', 'delete', 'print', 'export'],
                                        'reporting': ['view', 'print', 'export'],
                                        'configuration': ['view', 'create', 'update', 'delete']
                                        } %}
                                        <div class="accordion-item">
                                            <h2 class="accordion-header" id="heading{{ module|capitalize }}">
                                                <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#collapse{{ module|capitalize }}"
                                                    aria-expanded="false"
                                                    aria-controls="collapse{{ module|capitalize }}">
                                                    {% set moduleLabels = {
                                                    'vehicule': 'Gestion des véhicules',
                                                    'affectation': 'Gestion des affectations',
                                                    'maintenance': 'Maintenance',
                                                    'reparation': 'Gestion des réparations',
                                                    'vidange_vehicule': 'Suivi des vidanges',
                                                    'voyage': 'Gestion des voyages',
                                                    'voyage_vehicule': 'Gestion des trajets de voyage',
                                                    'document': 'Gestion des documents',
                                                    'reporting': 'Reporting',
                                                    'configuration': 'Configuration'
                                                    } %}
                                                    {{ moduleLabels[module] ?? module }}
                                                </button>
                                            </h2>
                                            <div id="collapse{{ module|capitalize }}"
                                                class="accordion-collapse collapse"
                                                aria-labelledby="heading{{ module|capitalize }}"
                                                data-bs-parent="#permissionsAccordion">
                                                <div class="accordion-body">
                                                    <div class="row">
                                                        {% for action in actions %}
                                                        <div class="col-md-4 mb-2">
                                                            <div class="form-check">
                                                                <input class="form-check-input permission-checkbox"
                                                                    type="checkbox"
                                                                    id="permission_{{ module }}_{{ action }}"
                                                                    name="permissions[{{ module }}][{{ action }}]"
                                                                    value="1" {{ user.hasPermission(module, action)
                                                                    ? 'checked' : '' }} {{ 'ROLE_SUPER_ADMIN' in
                                                                    user.roles ? 'disabled' : '' }}>
                                                                <label class="form-check-label"
                                                                    for="permission_{{ module }}_{{ action }}">
                                                                    {% set actionLabels = {
                                                                    'view': 'Voir',
                                                                    'create': 'Créer',
                                                                    'update': 'Modifier',
                                                                    'delete': 'Supprimer',
                                                                    'print': 'Imprimer',
                                                                    'export': 'Exporter'
                                                                    } %}
                                                                    {{ actionLabels[action] ?? action }}
                                                                </label>
                                                            </div>
                                                        </div>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        {% endfor %}
                                    </div>
                                </div>

                                <div class="form-footer">
                                    <button type="submit" class="btn btn-primary">Modifier</button>
                                    <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Retour à la
                                        liste</a>
                                </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Désactiver les permissions pour les super administrateurs
        const superAdminCheckbox = document.getElementById('role_super_admin');
        const permissionCheckboxes = document.querySelectorAll('.permission-checkbox');

        function togglePermissions() {
            const isSuperAdmin = superAdminCheckbox.checked;
            permissionCheckboxes.forEach(checkbox => {
                checkbox.disabled = isSuperAdmin;
                if (isSuperAdmin) {
                    checkbox.checked = true;
                }
            });
        }

        // Initial state
        togglePermissions();

        // Écouter les changements sur le checkbox Super Admin
        superAdminCheckbox.addEventListener('change', togglePermissions);

        // Écouter les changements sur les autres rôles
        document.getElementById('role_user').addEventListener('change', function () {
            if (!this.checked && !document.getElementById('role_admin').checked && !superAdminCheckbox.checked) {
                toastr.info('Un utilisateur doit avoir au moins le rôle "Utilisateur".');
                this.checked = true;
            }
        });

        document.getElementById('role_admin').addEventListener('change', function () {
            if (!this.checked && !document.getElementById('role_user').checked && !superAdminCheckbox.checked) {
                toastr.info('Un utilisateur doit avoir au moins le rôle "Utilisateur".');
                document.getElementById('role_user').checked = true;
            }
        });
    });
</script>
{% endblock %}