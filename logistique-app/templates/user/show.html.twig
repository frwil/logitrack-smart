{# templates/user/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Détails de l'Utilisateur{% endblock %}

{% block body %}

<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Détails de l'utilisateur</h3>
                    </div>
                    <div class="card-body">
                        <div class="datagrid">
                            <div class="datagrid-item">
                                <div class="datagrid-title">Nom complet</div>
                                <div class="datagrid-content">{{ user.prenom }} {{ user.nom }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Email</div>
                                <div class="datagrid-content">{{ user.email }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Téléphone</div>
                                <div class="datagrid-content">{{ user.telephone }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Rôles</div>
                                <div class="datagrid-content">{{ user.roles|join(', ') }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Région</div>
                                <div class="datagrid-content">{{ user.region ? user.region.nom : 'Aucune' }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Statut</div>
                                <div class="datagrid-content">
                                    <span class="badge text-{{ user.isActive ? 'bg-success' : 'bg-danger' }}">
                                        {{ user.isActive ? 'Actif' : 'Inactif' }}
                                    </span>
                                </div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Créé le</div>
                                <div class="datagrid-content">{{ user.createdAt|date('d/m/Y H:i') }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">Dernière connexion</div>
                                <div class="datagrid-content">{{ user.lastLogin ? user.lastLogin|date('d/m/Y H:i') :
                                    'Jamais' }}</div>
                            </div>
                            {% if user.permissions is not empty %}
                            <div class="datagrid-item">
                                <div class="datagrid-title">Permissions</div>
                                <div class="datagrid-content">
                                    <div class="accordion" id="permissionsAccordion">
                                        {% for module, actions in user.permissions %}
                                        <div class="accordion-item">
                                            <h2 class="accordion-header" id="heading{{ module|capitalize }}">
                                                <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#collapse{{ module|capitalize }}"
                                                    aria-expanded="false"
                                                    aria-controls="collapse{{ module|capitalize }}">
                                                    {% set moduleLabels = {
                                                    'vehicule': 'Gestion des véhicules',
                                                    'affectation': 'Gestion des affectations',
                                                    'maintenance': 'Maintenance',
                                                    'reparation': 'Gestion des réparations',
                                                    'vidange_vehicule': 'Suivi des vidanges',
                                                    'voyage': 'Gestion des voyages',
                                                    'voyage_vehicule': 'Gestion des trajets de voyage',
                                                    'document': 'Gestion des documents',
                                                    'reporting': 'Reporting',
                                                    'configuration': 'Configuration'
                                                    } %}
                                                    {{ moduleLabels[module] ?? module }}
                                                </button>
                                            </h2>
                                            <div id="collapse{{ module|capitalize }}"
                                                class="accordion-collapse collapse"
                                                aria-labelledby="heading{{ module|capitalize }}"
                                                data-bs-parent="#permissionsAccordion">
                                                <div class="accordion-body">
                                                    <div class="row">
                                                        {% for action, hasPermission in actions %}
                                                        {% if hasPermission %}
                                                        <div class="col-md-4 mb-2">
                                                            <span class="badge text-bg-success">{% set actionLabels = {
                                                                'view': 'Voir',
                                                                'create': 'Créer',
                                                                'update': 'Modifier',
                                                                'delete': 'Supprimer',
                                                                'print': 'Imprimer',
                                                                'export': 'Exporter'
                                                                } %}
                                                                {{ actionLabels[action] ?? action }}</span>
                                                        </div>
                                                        {% endif %}
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning">Modifier</a>
                        <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Retour à la liste</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}