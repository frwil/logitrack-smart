{% extends 'base.html.twig' %}

{% block title %}Modifier l'Affectation #{{ affectation.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Modifier l'affectation #{{ affectation.id }}</h3>
                            <div class="ms-auto">
                                <a href="{{ path('app_affectation_vehicule_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Retour à la liste
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <form method="post" class="needs-validation" novalidate id="affectationForm">
                                <input type="hidden" name="_token" value="{{ csrf_token('affectation_edit' ~ affectation.id) }}">
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="id_vehicule">Véhicule</label>
                                            <select class="form-select" id="id_vehicule" name="id_vehicule" required>
                                                <option value="">Sélectionner un véhicule</option>
                                                {% for vehicule in vehicules %}
                                                    <option value="{{ vehicule.id }}" {{ affectation.idVehicule.id == vehicule.id ? 'selected' : '' }}>
                                                        {{ vehicule.immatriculationVehicule }} - {{ vehicule.idMarque.nomMarque }} {{ vehicule.modeleVehicule.nomModele }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            <div class="invalid-feedback">
                                                Veuillez sélectionner un véhicule.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="id_chauffeur">Chauffeur</label>
                                            <select class="form-select" id="id_chauffeur" name="id_chauffeur" required>
                                                <option value="">Sélectionner un chauffeur</option>
                                                {% for chauffeur in chauffeurs %}
                                                    <option value="{{ chauffeur.id }}" {{ affectation.idChauffeur.id == chauffeur.id ? 'selected' : '' }}>
                                                        {{ chauffeur.nom }} {{ chauffeur.prenom }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            <div class="invalid-feedback">
                                                Veuillez sélectionner un chauffeur.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="date_debut_affectation">Date de début</label>
                                            <input type="datetime-local" class="form-control" id="date_debut_affectation" name="date_debut_affectation" 
                                                   value="{{ affectation.dateDebutAffectation|date('Y-m-d\\TH:i') }}" required>
                                            <div class="invalid-feedback">
                                                Veuillez saisir une date de début.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="date_fin_affectation">Date de fin (optionnelle)</label>
                                            <input type="datetime-local" class="form-control" id="date_fin_affectation" name="date_fin_affectation" 
                                                   value="{{ affectation.dateFinAffectation ? affectation.dateFinAffectation|date('Y-m-d\\TH:i') : '' }}">
                                            <div class="form-text">
                                                Lorsque l'affectation est marquée comme fermée, la date de fin sera automatiquement définie à la date du jour si elle n'est pas déjà renseignée.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="id_type_utilisation">Type d'utilisation</label>
                                            <select class="form-select" id="id_type_utilisation" name="id_type_utilisation" required>
                                                <option value="">Sélectionner un type</option>
                                                {% for type in typesUtilisation %}
                                                    <option value="{{ type.id }}" {{ affectation.idTypeUtilisation.id == type.id ? 'selected' : '' }}>
                                                        {{ type.nom }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            <div class="invalid-feedback">
                                                Veuillez sélectionner un type d'utilisation.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="id_mode_utilisation">Mode d'utilisation</label>
                                            <select class="form-select" id="id_mode_utilisation" name="id_mode_utilisation" required>
                                                <option value="">Sélectionner un mode</option>
                                                {% for mode in modesUtilisation %}
                                                    <option value="{{ mode.id }}" {{ affectation.idModeUtilisation.id == mode.id ? 'selected' : '' }}>
                                                        {{ mode.nom }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            <div class="invalid-feedback">
                                                Veuillez sélectionner un mode d'utilisation.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="id_entite">Entité</label>
                                            <select class="form-select" id="id_entite" name="id_entite" required>
                                                <option value="">Sélectionner une entité</option>
                                                {% for entite in entites %}
                                                    <option value="{{ entite.id }}" {{ affectation.idEntite.id == entite.id ? 'selected' : '' }}>
                                                        {{ entite.libelle }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            <div class="invalid-feedback">
                                                Veuillez sélectionner une entité.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label" for="id_region">Région (optionnelle)</label>
                                            <select class="form-select" id="id_region" name="id_region">
                                                <option value="">Sélectionner une région</option>
                                                {% for region in regions %}
                                                    <option value="{{ region.id }}" {{ affectation.idRegion and affectation.idRegion.id == region.id ? 'selected' : '' }}>
                                                        {{ region.nom }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-12">
                                        <div class="mb-3">
                                            <label class="form-label" for="objet_affectation">Objet de l'affectation</label>
                                            <textarea class="form-control" id="objet_affectation" name="objet_affectation" rows="3" required>{{ affectation.objetAffectation }}</textarea>
                                            <div class="invalid-feedback">
                                                Veuillez saisir l'objet de l'affectation.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Ajout de la checkbox is_ferme pour l'édition -->
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <div class="form-check">
                                                <input type="hidden" name="is_ferme" value="0">
                                                <input class="form-check-input" type="checkbox" id="is_ferme" name="is_ferme" value="1" {{ affectation.isFerme ? 'checked' : '' }}>
                                                <label class="form-check-label" for="is_ferme">
                                                    Affectation fermée
                                                </label>
                                            </div>
                                            <div class="form-text">
                                                Si cochée, l'affectation sera marquée comme fermée et la date de fin sera automatiquement définie à la date du jour lors de l'enregistrement.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-4">
                                    <button type="submit" class="btn btn-primary me-2">
                                        <i class="fas fa-save me-2"></i>
                                        Enregistrer les modifications
                                    </button>
                                    <a href="{{ path('app_affectation_vehicule_show', {'id': affectation.id}) }}" class="btn btn-info me-2">
                                        <i class="fas fa-eye me-2"></i>
                                        Voir les détails
                                    </a>
                                    <a href="{{ path('app_affectation_vehicule_index') }}" class="btn btn-secondary">
                                        <i class="fas fa-times me-2"></i>
                                        Annuler
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Validation Bootstrap du formulaire
        (function () {
            'use strict'
            
            var forms = document.querySelectorAll('.needs-validation')
            
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
{% endblock %}