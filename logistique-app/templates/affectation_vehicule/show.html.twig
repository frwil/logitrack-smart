{% extends 'base.html.twig' %}

{% block title %}Détails de l'Affectation #{{ affectation.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Détails de l'affectation #{{ affectation.id }}</h3>
                            <div class="ms-auto">
                                <a href="{{ path('app_affectation_vehicule_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Retour à la liste
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <h5 class="text-muted">Véhicule</h5>
                                    <p class="fs-5">{{ affectation.idVehicule.immatriculationVehicule }} - {{ affectation.idVehicule.idMarque.nomMarque }} {{ affectation.idVehicule.modeleVehicule.nomModele }}</p>
                                </div>
                                <div class="col-md-6">
                                    <h5 class="text-muted">Chauffeur</h5>
                                    <p class="fs-5">{{ affectation.idChauffeur.nom }}</p>
                                </div>
                            </div>
                            
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <h5 class="text-muted">Dates</h5>
                                    <p><strong>Début:</strong> {{ affectation.dateDebutAffectation|date('d/m/Y H:i') }}</p>
                                    <p><strong>Fin:</strong> {{ affectation.dateFinAffectation ? affectation.dateFinAffectation|date('d/m/Y H:i') : 'Non définie' }}</p>
                                    <p>
                                        <strong>Statut:</strong> 
                                        {% if affectation.dateFinAffectation and affectation.dateFinAffectation < date() %}
                                            <span class="badge text-bg-success">Terminée</span>
                                        {% else %}
                                            <span class="badge text-bg-primary">Active</span>
                                        {% endif %}
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <h5 class="text-muted">Utilisation</h5>
                                    <p><strong>Type:</strong> {{ affectation.idTypeUtilisation.nom }}</p>
                                    <p><strong>Mode:</strong> {{ affectation.idModeUtilisation.nom }}</p>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-12">
                                    <h5 class="text-muted">Objet de l'affectation</h5>
                                    <p class="fs-6">{{ affectation.objetAffectation }}</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer d-flex">
                            <a href="{{ path('app_affectation_vehicule_edit', {'id': affectation.id}) }}" class="btn btn-primary me-2">
                                <i class="fas fa-edit me-2"></i>
                                Modifier
                            </a>
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                <form method="post" action="{{ path('app_affectation_vehicule_delete', {'id': affectation.id}) }}" 
                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette affectation ?');" 
                                      class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ affectation.id) }}">
                                    <button type="submit" class="btn btn-danger me-2">
                                        <i class="fas fa-trash me-2"></i>
                                        Supprimer
                                    </button>
                                </form>
                            {% endif %}
                            <a href="{{ path('app_affectation_vehicule_index') }}" class="btn btn-secondary">
                                <i class="fas fa-list me-2"></i>
                                Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}