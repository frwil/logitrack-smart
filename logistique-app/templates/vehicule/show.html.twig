{% extends 'base.html.twig' %}

{% block title %}Détails du Véhicule{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Détails du Véhicule</h3>
                    </div>
                    <div class="card-body">
                        <!-- Première ligne : Type de plaque et Immatriculation -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Type de véhicule</label>
                                    <div class="form-control-plaintext">{{ vehicule.typeImmatriculation.value }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Numéro d'immatriculation</label>
                                    <div class="form-control-plaintext">{{ vehicule.immatriculationVehicule }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Deuxième ligne : Date première utilisation et Expiration carte grise -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date première utilisation</label>
                                    <div class="form-control-plaintext">
                                        {{ vehicule.premiereUtilisation ? vehicule.premiereUtilisation|date('Y-m-d') : 'Non spécifiée' }}
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Expiration carte grise</label>
                                    <div class="form-control-plaintext">
                                        {{ vehicule.expirationCarteGrise ? vehicule.expirationCarteGrise|date('Y-m-d') : 'Non spécifiée' }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Troisième ligne : Chassis et Puissance -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Numéro de chassis</label>
                                    <div class="form-control-plaintext">{{ vehicule.chassisVehicule ?? 'Non spécifié' }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Puissance (CV)</label>
                                    <div class="form-control-plaintext">{{ vehicule.puissanceVehicule }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Quatrième ligne : Nombre de places et Capacité consommation -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Nombre de places</label>
                                    <div class="form-control-plaintext">{{ vehicule.nbPlace }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Consommation (L/100km)</label>
                                    <div class="form-control-plaintext">{{ vehicule.capaciteConsommationVehicule }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Cinquième ligne : Type carburant et Statut -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Type de carburant</label>
                                    <div class="form-control-plaintext">{{ vehicule.typeCarburant.value }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Statut</label>
                                    <div class="form-control-plaintext">{{ vehicule.statut ? 'Actif' : 'Inactif' }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Sixième ligne : Marque et Modèle -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Marque</label>
                                    <div class="form-control-plaintext">{{ vehicule.idMarque.nomMarque }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Modèle</label>
                                    <div class="form-control-plaintext">{{ vehicule.modeleVehicule.nomModele }}</div>
                                </div>
                            </div>
                        </div>

                        <!-- Septième ligne : Entité -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Entité</label>
                                    <div class="form-control-plaintext">{{ vehicule.idEntite.libelle }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <!-- Colonne vide pour l'alignement -->
                            </div>
                        </div>

                        <div class="mt-4">
                            <a href="{{ path('app_vehicule_edit', {'id': vehicule.id}) }}" class="btn btn-primary me-2">
                                <i class="fas fa-edit me-2"></i> Modifier
                            </a>
                            <a href="{{ path('app_vehicule_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i> Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}