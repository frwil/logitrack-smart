{% extends 'base.html.twig' %}

{% block title %}Liste des Véhicules{% endblock %}

{% block stylesheets %}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <!-- Cartes de statistiques -->
        <div class="row row-cards mb-3">
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-primary text-white avatar">
                                    <i class="fas fa-car"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ vehicules|length }} Véhicule(s)
                                </div>
                                <div class="text-muted">
                                    Total
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-green text-white avatar">
                                    <i class="fas fa-check-circle"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ vehiculesActifs }} Véhicule(s) actif(s)
                                </div>
                                <div class="text-muted">
                                    En service
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-warning text-white avatar">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ vehiculesAvecDocumentsExpirant }} Document(s) expirant
                                </div>
                                <div class="text-muted">
                                    Prochainement
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-danger text-white avatar">
                                    <i class="fas fa-times-circle"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ vehiculesAvecDocumentsExpires }} Document(s) expiré(s)
                                </div>
                                <div class="text-muted">
                                    Attention requise
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section des véhicules avec documents expirés/expirant -->
        {% if vehiculesAlerte is defined and vehiculesAlerte|length > 0 %}
        <div class="row row-cards mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Véhicules nécessitant une attention</h3>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-vcenter text-nowrap" id="vehicule-table-alerts">
                                <thead>
                                    <tr>
                                        <th>Immatriculation</th>
                                        <th>Marque/Modèle</th>
                                        <th>Problème</th>
                                        <th>Document concerné</th>
                                        <th>Date d'expiration</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for alerte in vehiculesAlerte %}
                                    <tr>
                                        <td>{{ alerte.vehicule.immatriculationVehicule }}</td>
                                        <td>{{ alerte.vehicule.idMarque.nomMarque }} / {{ alerte.vehicule.modeleVehicule ? alerte.vehicule.modeleVehicule.nomModele : '' }}</td>
                                        <td>
                                            {% if alerte.joursRestants < 0 %}
                                                <span class="badge text-bg-danger">Expiré</span>
                                            {% else %}
                                                <span class="badge text-bg-warning">Expire bientôt</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ alerte.document.typeDocument.nom }}</td>
                                        <td>
                                            {{ alerte.document.dateExpiration|date('d/m/Y') }}
                                            {% if alerte.joursRestants < 0 %}
                                                <div class="text-danger">(Il y a {{ -alerte.joursRestants }} jours)</div>
                                            {% else %}
                                                <div class="text-warning">(Dans {{ alerte.joursRestants }} jours)</div>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_document_vehicule_index', {'id': alerte.vehicule.id}) }}" 
                                               class="btn btn-sm btn-primary">
                                                Voir documents
                                            </a>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Tableau principal des véhicules -->
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Véhicules</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_vehicule_alertes') }}" class="btn btn-warning me-2">
                                <i class="fas fa-exclamation-triangle me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Véhicules avec alertes</span>
                                {% if vehiculesAvecDocumentsExpirant > 0 or vehiculesAvecDocumentsExpires > 0 %}
                                <span class="badge bg-danger ms-1">{{ vehiculesAvecDocumentsExpirant + vehiculesAvecDocumentsExpires }}</span>
                                {% endif %}
                            </a>
                            <a href="{{ path('app_vehicule_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Nouveau Véhicule</span>
                                <i class="fas fa-plus d-sm-none"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="vehicule-table" class="table card-table table-vcenter text-nowrap datatable">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Immatriculation</th>
                                        <th>Marque</th>
                                        <th>Modèle</th>
                                        <th>Puissance (CV)</th>
                                        <th>Places</th>
                                        <th>Carburant</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for vehicule in vehicules %}
                                    <tr>
                                        <td>{{ vehicule.id }}</td>
                                        <td>{{ vehicule.immatriculationVehicule }}</td>
                                        <td>{% if vehicule.idMarque %}
                                            <a href="{{ path('app_marque_vehicule_show', {'id': vehicule.idMarque.id}) }}">
                                                {{ vehicule.idMarque.nomMarque }}
                                            </a>
                                            {% else %}
                                            N/A
                                            {% endif %}
                                        </td>
                                        <td>{% if vehicule.modeleVehicule %}
                                            <a href="{{ path('app_modele_vehicule_show', {'id': vehicule.modeleVehicule.id}) }}">
                                                {{ vehicule.modeleVehicule.nomModele }}
                                            </a>
                                            {% else %}
                                            N/A
                                            {% endif %}
                                        </td>
                                        <td>{{ vehicule.puissanceVehicule }}</td>
                                        <td>{{ vehicule.nbPlace }}</td>
                                        <td>{{ vehicule.typeCarburant.value }}</td>
                                        <td>
                                            {% if vehicule.statut %}
                                            <span class="badge text-bg-success">Actif</span>
                                            {% else %}
                                            <span class="badge text-bg-danger">Inactif</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="{{ path('app_vehicule_show', {'id': vehicule.id}) }}"
                                                    class="btn btn-icon btn-sm" title="Détails">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('app_vehicule_edit', {'id': vehicule.id}) }}"
                                                    class="btn btn-icon btn-sm" title="Modifier">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                {# Nouveau bouton pour accéder aux documents #}
                                                <a href="{{ path('app_document_vehicule_index', {'id': vehicule.id}) }}"
                                                    class="btn btn-icon btn-sm" title="Documents">
                                                    <i class="fas fa-folder"></i>
                                                </a>
                                                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                                <form method="post"
                                                    action="{{ path('app_vehicule_delete', {'id': vehicule.id}) }}"
                                                    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce véhicule ?');"
                                                    class="d-inline">
                                                    <input type="hidden" name="_token"
                                                        value="{{ csrf_token('delete' ~ vehicule.id) }}">
                                                    <button type="submit" class="btn btn-icon btn-sm text-danger"
                                                        title="Supprimer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function () {
        $('#vehicule-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            },
            order: [[1, 'asc']],
            responsive: true,
            columnDefs: [
                { responsivePriority: 1, targets: 1 },
                { responsivePriority: 2, targets: -1 }
            ]
        });
        $('#vehicule-table-alerts').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            },
            order: [[1, 'asc']],
            responsive: true,
            pageLength:5,
            columnDefs: [
                { responsivePriority: 1, targets: 1 },
                { responsivePriority: 2, targets: -1 }
            ]
        });
    });
</script>
{% endblock %}