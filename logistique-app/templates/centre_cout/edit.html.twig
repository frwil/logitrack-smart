{% extends 'base.html.twig' %}

{% block title %}Modifier le Centre de Coût - {{ centre_cout.libelle }}{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Modifier le Centre de Coût</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_centre_cout_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Retour à la liste</span>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        {% if centre_cout.nombreBonsReparation > 0 %}
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            Ce centre de coût ne peut pas être modifié car il est associé à {{ centre_cout.nombreBonsReparation }} bon(s) de réparation.
                        </div>
                        {% else %}
                        <form method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="libelle" class="form-label required">Libellé</label>
                                        <input type="text" class="form-control" id="libelle" name="libelle" value="{{ libelle }}" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Statut</label>
                                        <div>
                                            <label class="form-check form-check-inline">
                                                <input class="form-check-input" type="checkbox" id="estActif" name="estActif" value="1" {{ estActif ? 'checked' : '' }}>
                                                <span class="form-check-label">Actif</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea class="form-control" id="description" name="description" rows="4">{{ description }}</textarea>
                            </div>
                            
                            <div class="form-footer">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Enregistrer
                                </button>
                                <a href="{{ path('app_centre_cout_index') }}" class="btn btn-secondary">Annuler</a>
                            </div>
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}