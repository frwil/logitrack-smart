{% extends 'base.html.twig' %}

{% block title %}Liste des Centres de Coût{% endblock %}

{% block stylesheets %}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Centres de Coût</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_centre_cout_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Nouveau Centre</span>
                                <i class="fas fa-plus d-sm-none"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="centre-cout-table" class="table card-table table-vcenter text-nowrap datatable">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Libellé</th>
                                        <th>Description</th>
                                        <th>Nombre de Bons</th>
                                        <th>Coût Total</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for centre_cout in centre_couts %}
                                    <tr>
                                        <td>{{ centre_cout.id }}</td>
                                        <td>{{ centre_cout.libelle }}</td>
                                        <td>{{ centre_cout.description|default('N/A') }}</td>
                                        <td>{{ centre_cout.nombreBonsReparation }}</td>
                                        <td>{{ centre_cout.coutTotalReparations|format_currency('EUR') }}</td>
                                        <td>
                                            {% if centre_cout.estActif %}
                                            <span class="badge text-bg-success">Actif</span>
                                            {% else %}
                                            <span class="badge text-bg-danger">Inactif</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_centre_cout_show', {'id': centre_cout.id}) }}"
                                                class="btn btn-icon btn-sm" title="Détails">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_centre_cout_edit', {'id': centre_cout.id}) }}"
                                                class="btn btn-icon btn-sm" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                            <form method="post"
                                                action="{{ path('app_centre_cout_delete', {'id': centre_cout.id}) }}"
                                                onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce centre de coût ?');"
                                                class="d-inline">
                                                <input type="hidden" name="_token"
                                                    value="{{ csrf_token('delete' ~ centre_cout.id) }}">
                                                <button type="submit" class="btn btn-icon btn-sm text-danger"
                                                    title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function () {
        $('#centre-cout-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            },
            order: [[1, 'asc']],
            responsive: true,
            columnDefs: [
                { responsivePriority: 1, targets: 1 },
                { responsivePriority: 2, targets: -1 }
            ]
        });
    });
</script>
{% endblock %}