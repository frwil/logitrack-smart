{% extends 'base.html.twig' %}

{% block title %}Liste des Types d'Utilisation de Véhicule{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card card-table">
                    <div class="card-header">
                        <h3 class="card-title">Types d'Utilisation de Véhicule</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_type_utilisation_vehicule_new') }}" class="btn btn-primary d-none d-sm-inline-block">
                                <i class="fas fa-plus me-2"></i> Nouveau Type
                            </a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table id="type-utilisation-table" class="table card-table table-vcenter text-nowrap datatable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Nom</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for type_utilisation_vehicule in type_utilisation_vehicules %}
                                <tr>
                                    <td>{{ type_utilisation_vehicule.id }}</td>
                                    <td>{{ type_utilisation_vehicule.nom }}</td>
                                    <td>
                                        <a href="{{ path('app_type_utilisation_vehicule_show', {'id': type_utilisation_vehicule.id}) }}" class="btn btn-icon btn-sm" title="Détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_type_utilisation_vehicule_edit', {'id': type_utilisation_vehicule.id}) }}" class="btn btn-icon btn-sm" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                            <form method="post" action="{{ path('app_type_utilisation_vehicule_delete', {'id': type_utilisation_vehicule.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce type ?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type_utilisation_vehicule.id) }}">
                                                <button type="submit" class="btn btn-icon btn-sm text-danger" title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3">Aucun type d'utilisation de véhicule trouvé.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function() {
        $('#type-utilisation-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            }
        });
    });
</script>
{% endblock %}