{% extends 'base.html.twig' %}

{% block title %}Liste des Bons de Réparation{% endblock %}

{% block stylesheets %}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Bons de Réparation</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_bon_reparation_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Nouveau Bon</span>
                                <i class="fas fa-plus d-sm-none"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="bon-reparation-table" class="table card-table table-vcenter text-nowrap datatable">
                                <thead>
                                    <tr>
                                        <th>N° Bon</th>
                                        <th>Véhicule</th>
                                        <th>Date Entrée</th>
                                        <th>Prestataire</th>
                                        <th>Montant</th>
                                        <th>Statut</th>
                                        <th>Clôture</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for bon_reparation in bon_reparations %}
                                    <tr>
                                        <td>{{ bon_reparation.numero }}</td>
                                        <td>
                                            {% if bon_reparation.affectation and bon_reparation.affectation.idVehicule %}
                                                {{ bon_reparation.affectation.idVehicule.immatriculationVehicule }}
                                            {% else %}
                                                N/A
                                            {% endif %}
                                        </td>
                                        <td>{{ bon_reparation.dateEntree|date('d/m/Y') }}</td>
                                        <td>{{ bon_reparation.prestataire ? bon_reparation.prestataire.nom : 'N/A' }}</td>
                                        <td>{{ bon_reparation.coutTotal|number_format(0, ',', ' ') }} FCFA</td>
                                        <td>
                                            {% if bon_reparation.statut %}
                                                <span class="badge" style="background-color: {{ bon_reparation.statut.couleurAvecDefaut }}; color: white;">
                                                    {{ bon_reparation.statut.libelle }}
                                                </span>
                                            {% else %}
                                                <span class="badge text-bg-secondary">N/A</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if bon_reparation.cloture %}
                                                <span class="badge text-bg-success">Oui</span>
                                            {% else %}
                                                <span class="badge text-bg-warning">Non</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_bon_reparation_show', {'id': bon_reparation.id}) }}"
                                                class="btn btn-icon btn-sm" title="Détails">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_bon_reparation_edit', {'id': bon_reparation.id}) }}"
                                                class="btn btn-icon btn-sm" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                            <form method="post"
                                                action="{{ path('app_bon_reparation_delete', {'id': bon_reparation.id}) }}"
                                                onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce bon de réparation ?');"
                                                class="d-inline">
                                                <input type="hidden" name="_token"
                                                    value="{{ csrf_token('delete' ~ bon_reparation.id) }}">
                                                <button type="submit" class="btn btn-icon btn-sm text-danger"
                                                    title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function () {
        $('#bon-reparation-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            },
            order: [[2, 'desc']],
            responsive: true,
            columnDefs: [
                { responsivePriority: 1, targets: 0 },
                { responsivePriority: 2, targets: -1 }
            ]
        });
    });
</script>
{% endblock %}