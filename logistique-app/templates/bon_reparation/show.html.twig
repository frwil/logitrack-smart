{% extends 'base.html.twig' %}

{% block title %}Détails du Bon de Réparation - {{ bon_reparation.numero }}{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Détails du Bon de Réparation</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_bon_reparation_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Retour à la liste</span>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">N° Bon</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.numero }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Statut</label>
                                    <div class="form-control-plaintext">
                                        {% if bon_reparation.statut %}
                                            <span class="badge" style="background-color: {{ bon_reparation.statut.couleurAvecDefaut }}; color: white;">
                                                {{ bon_reparation.statut.libelle }}
                                            </span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">N/A</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Véhicule</label>
                                    <div class="form-control-plaintext">
                                        {% if bon_reparation.affectation and bon_reparation.affectation.idVehicule %}
                                            {{ bon_reparation.affectation.idVehicule.immatriculationVehicule }}
                                            ({{ bon_reparation.affectation.idVehicule.idMarque.nomMarque }} {{ bon_reparation.affectation.idVehicule.modeleVehicule.nomModele }})
                                        {% else %}
                                            N/A
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Type d'exécution</label>
                                    <div class="form-control-plaintext">
                                        {{ bon_reparation.typeExecution ? 'Interne' : 'Externe' }}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date d'entrée</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dateEntree|date('d/m/Y') }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date prévue de sortie</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.datePrevueSortie|date('d/m/Y') }}</div>
                                </div>
                            </div>
                        </div>
                        
                        {% if bon_reparation.dateFinReparation %}
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date de fin de réparation</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dateFinReparation|date('d/m/Y') }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Durée effective</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dureeEffective }} jours</div>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Prestataire</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.prestataire ? bon_reparation.prestataire.nom : 'N/A' }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Centre de coût</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.centreCout ? bon_reparation.centreCout.libelle : 'N/A' }}</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Montant réparation</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.montantReparation|number_format(0, ',', ' ') }} €</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Plus/Moins Value</label>
                                    <div class="form-control-plaintext">
                                        {% if bon_reparation.plusOuMoinsValue %}
                                            {{ bon_reparation.plusOuMoinsValue.libelle }}: {{ bon_reparation.plusOuMoinsValueValeur|number_format(0, ',', ' ') }} €
                                        {% else %}
                                            N/A
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Coût total</label>
                                    <div class="form-control-plaintext fw-bold">{{ bon_reparation.coutTotal|number_format(0, ',', ' ') }} €</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Durée prévue</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dureeReparation }} jours</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Diagnostic</label>
                            <div class="form-control-plaintext">{{ bon_reparation.diagnostic|nl2br }}</div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Destination</label>
                            <div class="form-control-plaintext">{{ bon_reparation.destination }}</div>
                        </div>
                        
                        {% if bon_reparation.observations %}
                        <div class="mb-3">
                            <label class="form-label">Observations</label>
                            <div class="form-control-plaintext">{{ bon_reparation.observations|nl2br }}</div>
                        </div>
                        {% endif %}
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date de justification</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dateJustification|date('d/m/Y') }}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Clôture</label>
                                    <div class="form-control-plaintext">
                                        {% if bon_reparation.cloture %}
                                            <span class="badge text-bg-success">Oui</span>
                                        {% else %}
                                            <span class="badge text-bg-warning">Non</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date de création</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dateCreation|date('d/m/Y H:i') }}</div>
                                </div>
                            </div>
                            {% if bon_reparation.dateModification %}
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date de modification</label>
                                    <div class="form-control-plaintext">{{ bon_reparation.dateModification|date('d/m/Y H:i') }}</div>
                                </div>
                            </div>
                            {% endif %}
                        </div>
                        
                        <div class="mt-3">
                            <a href="{{ path('app_bon_reparation_edit', {'id': bon_reparation.id}) }}" class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i>Modifier
                            </a>
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                {% if not bon_reparation.cloture %}
                                <form method="post" action="{{ path('app_bon_reparation_cloturer', {'id': bon_reparation.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir clôturer ce bon de réparation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cloturer' ~ bon_reparation.id) }}">
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-lock me-2"></i>Clôturer
                                    </button>
                                </form>
                                {% else %}
                                <form method="post" action="{{ path('app_bon_reparation_reouvrir', {'id': bon_reparation.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir réouvrir ce bon de réparation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reouvrir' ~ bon_reparation.id) }}">
                                    <button type="submit" class="btn btn-info">
                                        <i class="fas fa-unlock me-2"></i>Réouvrir
                                    </button>
                                </form>
                                {% endif %}
                                <form method="post" action="{{ path('app_bon_reparation_delete', {'id': bon_reparation.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce bon de réparation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ bon_reparation.id) }}">
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-trash me-2"></i>Supprimer
                                    </button>
                                </form>
                            {% endif %}
                            <a href="{{ path('app_bon_reparation_index') }}" class="btn btn-secondary">Retour à la liste</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}