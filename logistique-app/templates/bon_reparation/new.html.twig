{% extends 'base.html.twig' %}

{% block title %}Nouveau Bon de Réparation{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Créer un nouveau Bon de Réparation</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_bon_reparation_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Retour à la liste</span>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="mb-3">
                                        <label for="affectation" class="form-label required">Véhicule
                                            (Affectation)</label>
                                        <div class="input-group">
                                            <select class="form-select tom-select" id="affectation" name="affectation"
                                                required>
                                                <option value="">Sélectionner un véhicule</option>
                                                {% for affectation in affectations %}
                                                <option value="{{ affectation.id }}" {{
                                                    (form_data.affectation|default('')==affectation.id) ? 'selected'
                                                    : '' }}>
                                                    {{ affectation.idVehicule.immatriculationVehicule }} - {{
                                                    affectation.idVehicule.idMarque.nomMarque }} {{
                                                    affectation.idVehicule.modeleVehicule.nomModele }}
                                                </option>
                                                {% endfor %}
                                            </select>
                                            <button type="button" class="btn btn-primary" data-bs-toggle="modal"
                                                data-bs-target="#modal-affectation">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dateEntree" class="form-label required">Date d'entrée</label>
                                        <input type="date" class="form-control" id="dateEntree" name="dateEntree"
                                            value="{{ form_data.dateEntree|default('now'|date('Y-m-d')) }}" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="datePrevueSortie" class="form-label required">Date prévue de
                                            sortie</label>
                                        <input type="date" class="form-control" id="datePrevueSortie"
                                            name="datePrevueSortie"
                                            value="{{ form_data.datePrevueSortie|default('now'|date('Y-m-d')) }}"
                                            required>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="diagnostic" class="form-label required">Diagnostic</label>
                                <textarea class="form-control" id="diagnostic" name="diagnostic" rows="4"
                                    required>{{ form_data.diagnostic|default('') }}</textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label required">Type d'exécution</label>
                                        <div>
                                            <label class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="typeExecution"
                                                    value="1" {{ (form_data.typeExecution|default('1')=='1' )
                                                    ? 'checked' : '' }} required>
                                                <span class="form-check-label">Interne</span>
                                            </label>
                                            <label class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="typeExecution"
                                                    value="0" {{ (form_data.typeExecution|default('')=='0' ) ? 'checked'
                                                    : '' }}>
                                                <span class="form-check-label">Externe</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="prestataire" class="form-label">Prestataire</label>
                                        <div class="input-group">
                                            <select class="form-select tom-select" id="prestataire" name="prestataire">
                                                <option value="">Sélectionner un prestataire</option>
                                                {% for prestataire in prestataires %}
                                                <option value="{{ prestataire.id }}" {{
                                                    (form_data.prestataire|default('')==prestataire.id) ? 'selected'
                                                    : '' }}>
                                                    {{ prestataire.nom }}
                                                </option>
                                                {% endfor %}
                                            </select>
                                            <button type="button" class="btn btn-primary" data-bs-toggle="modal"
                                                data-bs-target="#modal-prestataire">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="montantReparation" class="form-label required">Montant réparation
                                            (MCFA)</label>
                                        <input type="number" class="form-control" id="montantReparation"
                                            name="montantReparation"
                                            value="{{ form_data.montantReparation|default('0') }}" min="0" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="plusOuMoinsValue" class="form-label">Plus/Moins Value</label>
                                        <select class="form-select tom-select" id="plusOuMoinsValue"
                                            name="plusOuMoinsValue">
                                            <option value="">Sélectionner une valeur</option>
                                            {% for value in plusOuMoinsValues %}
                                            <option value="{{ value.id }}" {{
                                                (form_data.plusOuMoinsValue|default('')==value.id) ? 'selected' : '' }}>
                                                {{ value.libelle }}
                                            </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="plusOuMoinsValueValeur" class="form-label">Valeur Plus/Moins
                                            (FCFA)</label>
                                        <input type="number" class="form-control" id="plusOuMoinsValueValeur"
                                            name="plusOuMoinsValueValeur"
                                            value="{{ form_data.plusOuMoinsValueValeur|default('0') }}" min="0">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="destination" class="form-label required">Destination</label>
                                        <input type="text" class="form-control" id="destination" name="destination"
                                            value="{{ form_data.destination|default('') }}" required>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dureeReparation" class="form-label required">Durée prévue
                                            (jours)</label>
                                        <input type="number" class="form-control" id="dureeReparation"
                                            name="dureeReparation" value="{{ form_data.dureeReparation|default('0') }}"
                                            min="0" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dateJustification" class="form-label required">Date de
                                            justification</label>
                                        <input type="date" class="form-control" id="dateJustification"
                                            name="dateJustification"
                                            value="{{ form_data.dateJustification|default('now'|date('Y-m-d')) }}"
                                            required>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="centreCout" class="form-label">Centre de coût</label>
                                        <div class="input-group">
                                            <select class="form-select tom-select" id="centreCout" name="centreCout">
                                                <option value="">Sélectionner un centre de coût</option>
                                                {% for centreCout in centreCouts %}
                                                <option value="{{ centreCout.id }}" {{
                                                    (form_data.centreCout|default('')==centreCout.id) ? 'selected' : ''
                                                    }}>
                                                    {{ centreCout.libelle }}
                                                </option>
                                                {% endfor %}
                                            </select>
                                            <button type="button" class="btn btn-primary" data-bs-toggle="modal"
                                                data-bs-target="#modal-centre-cout">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="statut" class="form-label">Statut</label>
                                        <select class="form-select tom-select" id="statut" name="statut">
                                            <option value="">Sélectionner un statut</option>
                                            {% for statut in statuts %}
                                            <option value="{{ statut.id }}" {{ (form_data.statut|default('')==statut.id)
                                                ? 'selected' : '' }}>
                                                {{ statut.libelle }}
                                            </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="observations" class="form-label">Observations</label>
                                <textarea class="form-control" id="observations" name="observations"
                                    rows="3">{{ form_data.observations|default('') }}</textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Clôture</label>
                                <div>
                                    <label class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="cloture" name="cloture"
                                            value="1" {{ (form_data.cloture|default('')) ? 'checked' : '' }}>
                                        <span class="form-check-label">Clôturer le bon</span>
                                    </label>
                                </div>
                            </div>

                            <div class="form-footer">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Créer
                                </button>
                                <a href="{{ path('app_bon_reparation_index') }}" class="btn btn-secondary">Annuler</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal pour ajouter un prestataire -->
<div class="modal fade" id="modal-prestataire" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajouter un prestataire</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form-prestataire">
                    <div class="mb-3">
                        <label for="prestataire-nom" class="form-label">Nom</label>
                        <input type="text" class="form-control" id="prestataire-nom" name="nom" required>
                    </div>
                    <div class="mb-3">
                        <label for="prestataire-adresse" class="form-label">Adresse</label>
                        <textarea class="form-control" id="prestataire-adresse" name="adresse" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="prestataire-telephone" class="form-label">Téléphone</label>
                        <input type="text" class="form-control" id="prestataire-telephone" name="telephone">
                    </div>
                    <div class="mb-3">
                        <label for="prestataire-email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="prestataire-email" name="email">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="save-prestataire">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal pour ajouter un centre de coût -->
<div class="modal fade" id="modal-centre-cout" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajouter un centre de coût</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form-centre-cout">
                    <div class="mb-3">
                        <label for="centre-cout-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="centre-cout-libelle" name="libelle" required>
                    </div>
                    <div class="mb-3">
                        <label for="centre-cout-description" class="form-label">Description</label>
                        <textarea class="form-control" id="centre-cout-description" name="description"
                            rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="save-centre-cout">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal pour ajouter une plus ou moins value -->
<div class="modal fade" id="modal-plus-ou-moins-value" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajouter une plus ou moins value</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form-plus-ou-moins-value">
                    <div class="mb-3">
                        <label for="plus-ou-moins-value-libelle" class="form-label">Libellé</label>
                        <input type="text" class="form-control" id="plus-ou-moins-value-libelle" name="libelle"
                            required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label required">Type</label>
                        <div>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="typeValeur" value="1" checked
                                    required>
                                <span class="form-check-label">Plus-value</span>
                            </label>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="typeValeur" value="0">
                                <span class="form-check-label">Moins-value</span>
                            </label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="plus-ou-moins-value-description" class="form-label">Description</label>
                        <textarea class="form-control" id="plus-ou-moins-value-description" name="description"
                            rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="save-plus-ou-moins-value">Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal pour ajouter une affectation -->
<div class="modal fade" id="modal-affectation" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajouter une affectation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    La création d'une affectation nécessite plusieurs étapes. Veuillez utiliser le menu dédié.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                <a href="{{ path('app_affectation_vehicule_new') }}" class="btn btn-primary">Créer une affectation</a>
            </div>
        </div>
    </div>
</div>

<style>
    .ts-control {
        border: 1px solid #dadfe5;
        border-radius: 0.5rem;
        padding: 0.75rem 0.5rem;
    }

    .ts-wrapper.single .ts-control {
        background-image: none;
    }

    .ts-dropdown {
        border: 1px solid #dadfe5;
        border-radius: 0.5rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }

    .ts-dropdown .option {
        padding: 0.5rem 1rem;
    }

    .ts-dropdown .active {
        background-color: #f8f9fa;
    }

    .ts-dropdown .selected {
        background-color: #e9ecef;
    }

    .input-group .btn {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Fonction pour mettre à jour un select avec de nouvelles options
        function updateSelectOptions(selectId, options, selectedValue = null) {
            const select = document.getElementById(selectId);
            const tomSelect = select.tomselect;

            // Sauvegarder la valeur sélectionnée actuelle
            const currentValue = selectedValue || select.value;

            // Vider les options existantes
            tomSelect.clearOptions();

            // Ajouter l'option par défaut
            tomSelect.addOption({
                value: '',
                text: 'Sélectionner...'
            });

            // Ajouter les nouvelles options
            options.forEach(option => {
                tomSelect.addOption({
                    value: option.id,
                    text: option.libelle || option.nom
                });
            });

            // Restaurer la sélection précédente ou définir la nouvelle valeur
            if (currentValue) {
                tomSelect.setValue(currentValue);
            } else {
                tomSelect.setValue('');
            }

            tomSelect.refreshOptions();
        }

        // Initialiser tous les selects avec la classe tom-select
        new TomSelect('#affectation', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            },
            placeholder: 'Sélectionner un véhicule',
            maxOptions: null
        });

        new TomSelect('#prestataire', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            },
            placeholder: 'Sélectionner un prestataire',
            maxOptions: null
        });

        new TomSelect('#plusOuMoinsValue', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            },
            placeholder: 'Sélectionner une valeur',
            maxOptions: null
        });

        new TomSelect('#centreCout', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            },
            placeholder: 'Sélectionner un centre de coût',
            maxOptions: null
        });

        new TomSelect('#statut', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            },
            placeholder: 'Sélectionner un statut',
            maxOptions: null
        });

        // Gestion de l'ajout de prestataire
        document.getElementById('save-prestataire').addEventListener('click', function () {
            const formData = new FormData(document.getElementById('form-prestataire'));

            fetch("{{ path('app_prestataire_intervention_ajax_new') }}", {
                method: 'POST',
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Récupérer la liste actualisée des prestataires
                        fetch("{{ path('app_prestataire_intervention_list') }}")
                            .then(response => response.json())
                            .then(prestataires => {
                                updateSelectOptions('prestataire', prestataires, data.prestataire.id);

                                // Fermer le modal et réinitialiser le formulaire
                                const modal = bootstrap.Modal.getInstance(document.getElementById('modal-prestataire'));
                                modal.hide();
                                document.getElementById('form-prestataire').reset();

                                toastr.success('Prestataire ajouté avec succès');
                            });
                    } else {
                        toastr.error('Erreur: ' + data.message);
                    }
                })
                .catch(error => {
                    toastr.error('Erreur réseau');
                });
        });

        // Gestion de l'ajout de centre de coût
        document.getElementById('save-centre-cout').addEventListener('click', function () {
            const formData = new FormData(document.getElementById('form-centre-cout'));

            fetch("{{ path('app_centre_cout_ajax_new') }}", {
                method: 'POST',
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Récupérer la liste actualisée des centres de coût
                        fetch("{{ path('app_centre_cout_list') }}")
                            .then(response => response.json())
                            .then(centreCouts => {
                                updateSelectOptions('centreCout', centreCouts, data.centreCout.id);

                                // Fermer le modal et réinitialiser le formulaire
                                const modal = bootstrap.Modal.getInstance(document.getElementById('modal-centre-cout'));
                                modal.hide();
                                document.getElementById('form-centre-cout').reset();

                                toastr.success('Centre de coût ajouté avec succès');
                            });
                    } else {
                        toastr.error('Erreur: ' + data.message);
                    }
                })
                .catch(error => {
                    toastr.error('Erreur réseau');
                });
        });

        // Gestion de l'ajout de plus ou moins value
        document.getElementById('save-plus-ou-moins-value').addEventListener('click', function () {
            const formData = new FormData(document.getElementById('form-plus-ou-moins-value'));

            fetch("{{ path('app_plus_ou_moins_value_ajax_new') }}", {
                method: 'POST',
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Récupérer la liste actualisée des plus ou moins values
                        fetch("{{ path('app_plus_ou_moins_value_list') }}")
                            .then(response => response.json())
                            .then(plusOuMoinsValues => {
                                updateSelectOptions('plusOuMoinsValue', plusOuMoinsValues, data.plusOuMoinsValue.id);

                                // Fermer le modal et réinitialiser le formulaire
                                const modal = bootstrap.Modal.getInstance(document.getElementById('modal-plus-ou-moins-value'));
                                modal.hide();
                                document.getElementById('form-plus-ou-moins-value').reset();

                                toastr.success('Plus ou moins value ajoutée avec succès');
                            });
                    } else {
                        toastr.error('Erreur: ' + data.message);
                    }
                })
                .catch(error => {
                    toastr.error('Erreur réseau');
                });
        });
    });
</script>
{% endblock %}