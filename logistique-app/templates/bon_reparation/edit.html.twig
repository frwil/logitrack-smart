{% extends 'base.html.twig' %}

{% block title %}Modifier le Bon de Réparation - {{ bon_reparation.numero }}{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Modifier le Bon de Réparation</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_bon_reparation_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Retour à la liste</span>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="numero" class="form-label required">N° Bon</label>
                                        <input type="text" class="form-control" id="numero" name="numero" value="{{ form_data.numero|default(bon_reparation.numero) }}" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="affectation" class="form-label required">Véhicule (Affectation)</label>
                                        <select class="form-select" id="affectation" name="affectation" required>
                                            <option value="">Sélectionner un véhicule</option>
                                            {% for affectation in affectations %}
                                                <option value="{{ affectation.id }}" {{ (form_data.affectation|default(bon_reparation.affectation ? bon_reparation.affectation.id : '') == affectation.id) ? 'selected' : '' }}>
                                                    {{ affectation.idVehicule.immatriculationVehicule }} - {{ affectation.idVehicule.idMarque.nomMarque }} {{ affectation.idVehicule.modeleVehicule.nomModele }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dateEntree" class="form-label required">Date d'entrée</label>
                                        <input type="date" class="form-control" id="dateEntree" name="dateEntree" value="{{ form_data.dateEntree|default(bon_reparation.dateEntree ? bon_reparation.dateEntree|date('Y-m-d') : '') }}" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="datePrevueSortie" class="form-label required">Date prévue de sortie</label>
                                        <input type="date" class="form-control" id="datePrevueSortie" name="datePrevueSortie" value="{{ form_data.datePrevueSortie|default(bon_reparation.datePrevueSortie ? bon_reparation.datePrevueSortie|date('Y-m-d') : '') }}" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="diagnostic" class="form-label required">Diagnostic</label>
                                <textarea class="form-control" id="diagnostic" name="diagnostic" rows="4" required>{{ form_data.diagnostic|default(bon_reparation.diagnostic) }}</textarea>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label required">Type d'exécution</label>
                                        <div>
                                            <label class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="typeExecution" value="1" {{ (form_data.typeExecution|default(bon_reparation.typeExecution) == '1') ? 'checked' : '' }} required>
                                                <span class="form-check-label">Interne</span>
                                            </label>
                                            <label class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="typeExecution" value="0" {{ (form_data.typeExecution|default(bon_reparation.typeExecution) == '0') ? 'checked' : '' }}>
                                                <span class="form-check-label">Externe</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="prestataire" class="form-label">Prestataire</label>
                                        <select class="form-select" id="prestataire" name="prestataire">
                                            <option value="">Sélectionner un prestataire</option>
                                            {% for prestataire in prestataires %}
                                                <option value="{{ prestataire.id }}" {{ (form_data.prestataire|default(bon_reparation.prestataire ? bon_reparation.prestataire.id : '') == prestataire.id) ? 'selected' : '' }}>
                                                    {{ prestataire.nom }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="montantReparation" class="form-label required">Montant réparation (€)</label>
                                        <input type="number" class="form-control" id="montantReparation" name="montantReparation" value="{{ form_data.montantReparation|default(bon_reparation.montantReparation) }}" min="0" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="plusOuMoinsValue" class="form-label">Plus/Moins Value</label>
                                        <select class="form-select" id="plusOuMoinsValue" name="plusOuMoinsValue">
                                            <option value="">Sélectionner une valeur</option>
                                            {% for value in plusOuMoinsValues %}
                                                <option value="{{ value.id }}" {{ (form_data.plusOuMoinsValue|default(bon_reparation.plusOuMoinsValue ? bon_reparation.plusOuMoinsValue.id : '') == value.id) ? 'selected' : '' }}>
                                                    {{ value.libelle }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="plusOuMoinsValueValeur" class="form-label">Valeur Plus/Moins (€)</label>
                                        <input type="number" class="form-control" id="plusOuMoinsValueValeur" name="plusOuMoinsValueValeur" value="{{ form_data.plusOuMoinsValueValeur|default(bon_reparation.plusOuMoinsValueValeur) }}" min="0">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="destination" class="form-label required">Destination</label>
                                        <input type="text" class="form-control" id="destination" name="destination" value="{{ form_data.destination|default(bon_reparation.destination) }}" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dureeReparation" class="form-label required">Durée prévue (jours)</label>
                                        <input type="number" class="form-control" id="dureeReparation" name="dureeReparation" value="{{ form_data.dureeReparation|default(bon_reparation.dureeReparation) }}" min="0" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dateJustification" class="form-label required">Date de justification</label>
                                        <input type="date" class="form-control" id="dateJustification" name="dateJustification" value="{{ form_data.dateJustification|default(bon_reparation.dateJustification ? bon_reparation.dateJustification|date('Y-m-d') : '') }}" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="centreCout" class="form-label">Centre de coût</label>
                                        <select class="form-select" id="centreCout" name="centreCout">
                                            <option value="">Sélectionner un centre de coût</option>
                                            {% for centreCout in centreCouts %}
                                                <option value="{{ centreCout.id }}" {{ (form_data.centreCout|default(bon_reparation.centreCout ? bon_reparation.centreCout.id : '') == centreCout.id) ? 'selected' : '' }}>
                                                    {{ centreCout.libelle }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="statut" class="form-label">Statut</label>
                                        <select class="form-select" id="statut" name="statut">
                                            <option value="">Sélectionner un statut</option>
                                            {% for statut in statuts %}
                                                <option value="{{ statut.id }}" {{ (form_data.statut|default(bon_reparation.statut ? bon_reparation.statut.id : '') == statut.id) ? 'selected' : '' }}>
                                                    {{ statut.libelle }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="dateFinReparation" class="form-label">Date de fin de réparation</label>
                                        <input type="date" class="form-control" id="dateFinReparation" name="dateFinReparation" value="{{ form_data.dateFinReparation|default(bon_reparation.dateFinReparation ? bon_reparation.dateFinReparation|date('Y-m-d') : '') }}">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Clôture</label>
                                        <div>
                                            <label class="form-check form-check-inline">
                                                <input class="form-check-input" type="checkbox" id="cloture" name="cloture" value="1" {{ (form_data.cloture|default(bon_reparation.cloture)) ? 'checked' : '' }}>
                                                <span class="form-check-label">Clôturer le bon</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="observations" class="form-label">Observations</label>
                                <textarea class="form-control" id="observations" name="observations" rows="3">{{ form_data.observations|default(bon_reparation.observations) }}</textarea>
                            </div>
                            
                            <div class="form-footer">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Enregistrer
                                </button>
                                <a href="{{ path('app_bon_reparation_index') }}" class="btn btn-secondary">Annuler</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}