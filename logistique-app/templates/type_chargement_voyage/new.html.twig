{% extends 'base.html.twig' %}

{% block title %}Nouveau Type de Chargement de Voyage{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Créer un nouveau type de chargement</h3>
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ path('app_type_chargement_voyage_new') }}">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="libelle">Libellé</label>
                                        <input type="text" class="form-control" id="libelle" name="libelle" required>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i> Enregistrer
                                </button>
                                <a href="{{ path('app_type_chargement_voyage_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i> Retour à la liste
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
