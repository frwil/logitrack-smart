{% extends 'base.html.twig' %}

{% block title %}Types de Chargement de Voyage{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Liste des types de chargement</h3>
                        <div class="card-actions">
                            <a href="{{ path('app_type_chargement_voyage_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i> Nouveau type
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        {% if type_chargement_voyages is not empty %}
                            <div class="table-responsive">
                                <table id="typesChargementTable" class="table table-bordered table-hover w-100">
                                    <thead>
                                        <tr>
                                            <th>Libellé</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for type_chargement_voyage in type_chargement_voyages %}
                                            <tr>
                                                <td>{{ type_chargement_voyage.libelle }}</td>
                                                <td>
                                                    <div class="btn-group">
                                                        <a href="{{ path('app_type_chargement_voyage_show', {'id': type_chargement_voyage.id}) }}" class="btn btn-sm">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="{{ path('app_type_chargement_voyage_edit', {'id': type_chargement_voyage.id}) }}" class="btn btn-sm">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                                        <form method="post" action="{{ path('app_type_chargement_voyage_delete', {'id': type_chargement_voyage.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce type de chargement ?');">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type_chargement_voyage.id) }}">
                                                            <button type="submit" class="btn btn-sm">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                        {% endif %}
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="empty">
                                <div class="empty-icon">
                                    <i class="fas fa-box" style="font-size: 3rem;"></i>
                                </div>
                                <p class="empty-title">Aucun type de chargement enregistré</p>
                                <p class="empty-subtitle text-muted">
                                    Commencez par ajouter un nouveau type de chargement.
                                </p>
                                <div class="empty-action">
                                    <a href="{{ path('app_type_chargement_voyage_new') }}" class="btn btn-primary">
                                        <i class="fas fa-plus me-2"></i> Ajouter un type
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialiser DataTables si le tableau existe
        const typesChargementTable = document.getElementById('typesChargementTable');
        if (typesChargementTable) {
            $(typesChargementTable).DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/fr-FR.json'
                },
                responsive: true,
                columnDefs: [
                    { orderable: false, targets: 1 } // Désactiver le tri sur la colonne Actions
                ],
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100]
            });
        }
    });
</script>
{% endblock %}
