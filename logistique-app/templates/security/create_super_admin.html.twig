{% extends 'base.html.twig' %}

{% block title %}Création du Super Administrateur{% endblock %}

{% block body %}
<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center py-5" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
    <div class="row justify-content-center w-100">
        <div class="col-xl-5 col-lg-6 col-md-7">
            <div class="card shadow-lg border-0 rounded-20 overflow-hidden">
                <div class="card-header position-relative p-0">
                    <div class="bg-gradient-primary py-4 px-5 rounded-top-20">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-white p-2 rounded-circle shadow">
                                    <i class="fas fa-user-shield text-primary fa-2x"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-4">
                                <h2 class="card-title text-white mb-1">Super Administrateur</h2>
                                <p class="text-white-50 mb-0">Créez le premier compte administrateur</p>
                            </div>
                        </div>
                    </div>
                    <div class="position-absolute top-0 end-0 mt-3 me-3">
                        <div class="bg-white-20 p-1 rounded-circle">
                            <i class="fas fa-lock text-white fa-sm"></i>
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-5">
                    {% for flashError in app.flashes('error') %}
                        <div class="alert alert-danger rounded-10 d-flex align-items-center" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            {{ flashError }}
                        </div>
                    {% endfor %}
                    
                    <form method="post" class="needs-validation" novalidate>
                        <div class="mb-4">
                            <label for="email" class="form-label fw-semibold">Adresse Email</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0 rounded-start">
                                    <i class="fas fa-envelope text-primary"></i>
                                </span>
                                <input type="email" class="form-control rounded-end" id="email" name="email" 
                                       placeholder="votre@email.com" value="{{ user.email }}" required>
                                <div class="invalid-feedback">
                                    Veuillez saisir une adresse email valide.
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label for="prenom" class="form-label fw-semibold">Prénom</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0 rounded-start">
                                        <i class="fas fa-user text-primary"></i>
                                    </span>
                                    <input type="text" class="form-control rounded-end" id="prenom" name="prenom" 
                                           placeholder="Votre prénom" value="{{ user.prenom }}" required>
                                    <div class="invalid-feedback">
                                        Veuillez saisir votre prénom.
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6 mb-4">
                                <label for="nom" class="form-label fw-semibold">Nom</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0 rounded-start">
                                        <i class="fas fa-user-tag text-primary"></i>
                                    </span>
                                    <input type="text" class="form-control rounded-end" id="nom" name="nom" 
                                           placeholder="Votre nom" value="{{ user.nom }}" required>
                                    <div class="invalid-feedback">
                                        Veuillez saisir votre nom.
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label for="telephone" class="form-label fw-semibold">Téléphone (optionnel)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0 rounded-start">
                                    <i class="fas fa-phone text-primary"></i>
                                </span>
                                <input type="tel" class="form-control rounded-end" id="telephone" name="telephone" 
                                       placeholder="Votre numéro de téléphone" value="{{ user.telephone }}">
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">Mot de passe</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0 rounded-start">
                                    <i class="fas fa-key text-primary"></i>
                                </span>
                                <input type="password" class="form-control rounded-end password-input" 
                                       id="password" name="password" placeholder="Créez un mot de passe sécurisé" 
                                       required pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}">
                                <button type="button" class="btn btn-light border toggle-password" tabindex="-1">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <div class="invalid-feedback">
                                    Le mot de passe doit contenir au moins 8 caractères, une majuscule, une minuscule et un chiffre.
                                </div>
                            </div>
                            <div class="password-strength mt-2">
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                                </div>
                                <small class="text-muted strength-text">Force du mot de passe</small>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label for="confirm_password" class="form-label fw-semibold">Confirmer le mot de passe</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0 rounded-start">
                                    <i class="fas fa-lock text-primary"></i>
                                </span>
                                <input type="password" class="form-control rounded-end password-input" 
                                       id="confirm_password" name="confirm_password" 
                                       placeholder="Confirmez votre mot de passe" required>
                                <button type="button" class="btn btn-light border toggle-password" tabindex="-1">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <div class="invalid-feedback">
                                    Les mots de passe ne correspondent pas.
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="terms" required>
                            <label class="form-check-label" for="terms">
                                Je comprends que ce compte aura un accès complet au système
                            </label>
                            <div class="invalid-feedback">
                                Vous devez accepter les conditions.
                            </div>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-10 fw-semibold py-3">
                                <i class="fas fa-rocket me-2"></i>Créer le Super Administrateur
                            </button>
                        </div>
                    </form>
                </div>
                
                <div class="card-footer bg-light text-center py-3 rounded-bottom-20">
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Cette action ne peut être effectuée qu'une seule fois
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-20 {
        border-radius: 20px;
    }
    
    .rounded-top-20 {
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
    }
    
    .rounded-bottom-20 {
        border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;
    }
    
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e54c8 0%, #8f94fb 100%);
    }
    
    .card {
        border: none;
    }
    
    .input-group-text {
        transition: all 0.3s;
    }
    
    .input-group:focus-within .input-group-text {
        background-color: #e9ecef;
        border-color: #86b7fe;
    }
    
    .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(78, 84, 200, 0.25);
        border-color: #8f94fb;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #4e54c8 0%, #8f94fb 100%);
        border: none;
        transition: all 0.3s;
    }
    
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(78, 84, 200, 0.3);
    }
    
    .password-strength {
        display: none;
    }
    
    .toggle-password {
        border-left: none;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Validation du formulaire
    const form = document.querySelector('.needs-validation');
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirm_password');
    
    // Afficher/masquer le mot de passe
    document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function() {
            const input = this.closest('.input-group').querySelector('.password-input');
            const icon = this.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        });
    });
    
    // Vérification de la force du mot de passe
    password.addEventListener('input', function() {
        const strengthBar = document.querySelector('.password-strength .progress-bar');
        const strengthText = document.querySelector('.password-strength .strength-text');
        const strengthContainer = document.querySelector('.password-strength');
        
        if (password.value.length > 0) {
            strengthContainer.style.display = 'block';
            
            let strength = 0;
            if (password.value.length >= 8) strength += 25;
            if (password.value.match(/[a-z]+/)) strength += 25;
            if (password.value.match(/[A-Z]+/)) strength += 25;
            if (password.value.match(/[0-9]+/)) strength += 25;
            
            strengthBar.style.width = strength + '%';
            
            if (strength < 50) {
                strengthBar.classList.remove('bg-warning', 'bg-success');
                strengthBar.classList.add('bg-danger');
                strengthText.textContent = 'Faible';
            } else if (strength < 100) {
                strengthBar.classList.remove('bg-danger', 'bg-success');
                strengthBar.classList.add('bg-warning');
                strengthText.textContent = 'Moyen';
            } else {
                strengthBar.classList.remove('bg-danger', 'bg-warning');
                strengthBar.classList.add('bg-success');
                strengthText.textContent = 'Fort';
            }
        } else {
            strengthContainer.style.display = 'none';
        }
    });
    
    // Validation de la confirmation du mot de passe
    confirmPassword.addEventListener('input', function() {
        if (password.value !== confirmPassword.value) {
            confirmPassword.setCustomValidity("Les mots de passe ne correspondent pas.");
        } else {
            confirmPassword.setCustomValidity("");
        }
    });
    
    // Empêcher l'envoi du formulaire si invalide
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        
        form.classList.add('was-validated');
    }, false);
});
</script>
{% endblock %}