{% extends 'base.html.twig' %}

{% block title %}Kilométrage des véhicules - Logistique App{% endblock %}

{% block stylesheets %}
{{ parent() }}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Kilométrage des véhicules</h3>
                        <div class="card-actions">
                            <button class="btn btn-primary" onclick="window.print()">
                                <i class="fas fa-print"></i> Imprimer
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-vcenter table-mobile-md card-table" id="mileageTable">
                                <thead>
                                    <tr>
                                        <th>Véhicule</th>
                                        <th>Kilométrage actuel</th>
                                        <th>Date du dernier relevé</th>
                                        <th>Kilométrage moyen/mois</th>
                                        <th>Évolution</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for data in mileageData %}
                                    <tr>
                                        <td>
                                            {{ data.vehicule.immatriculation }}
                                            {% if data.vehicule.modele %}
                                            <br><small class="text-muted">{{ data.vehicule.modele }}</small>
                                            {% endif %}
                                        </td>
                                        <td>{{ data.dernierReleve.kilometrage|number_format(0, ',', ' ') }} km</td>
                                        <td>{{ data.dernierReleve.dateReleve|date('d/m/Y') }}</td>
                                        <td>{{ data.moyenneMensuelle|number_format(0, ',', ' ') }} km/mois</td>
                                        <td>
                                            {% if data.evolution != 0 %}
                                            <span
                                                class="badge {% if data.evolution > 0 %}text-bg-success{% else %}text-bg-danger{% endif %}">
                                                {{ data.evolution > 0 ? '+' : '' }}{{ data.evolution|number_format(1,
                                                ',', ' ') }}%
                                            </span>
                                            {% else %}
                                            <span class="badge text-bg-secondary">Stable</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Nouvelle section pour le graphique d'évolution #}
        <div class="row row-cards mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Évolution du kilométrage</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label for="affectation" class="form-label">Affectation</label>
                                <select class="form-select" id="affectation" name="affectation">
                                    <option value="">Sélectionnez une affectation</option>
                                    {% for affectation in affectations %}
                                    <option value="{{ affectation.id }}" {{ selectedAffectation==affectation.id
                                        ? 'selected' : '' }}>
                                        {{ affectation.idVehicule.immatriculationVehicule }} - {{
                                        affectation.idEntite.libelle }}
                                    </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="start_date" class="form-label">Date de début</label>
                                <input type="date" class="form-control" id="start_date" name="start_date"
                                    value="{{ startDate }}">
                            </div>
                            <div class="col-md-3">
                                <label for="end_date" class="form-label">Date de fin</label>
                                <input type="date" class="form-control" id="end_date" name="end_date"
                                    value="{{ endDate }}">
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary">Afficher</button>
                            </div>
                        </form>

                        {% if graphData is not empty %}
                        <div class="chart-container">
                            <canvas id="mileageChart" height="100"></canvas>
                        </div>
                        {% else %}
                        <div class="text-center py-4">
                            <i class="fas fa-info-circle me-2"></i>
                            Sélectionnez une affectation et une période pour voir l'évolution du kilométrage
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
{{ parent() }}
<script>
    // Initialiser DataTable
    document.addEventListener('DOMContentLoaded', function () {
        if (!$.fn.dataTable.isDataTable('#mileageTable')) {
            $('#mileageTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
                },
                pageLength: 25,
                order: [[1, 'desc']]
            });
        }

        // Initialiser Tom Select
        new TomSelect('#affectation', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            }
        });

        {% if graphData is not empty %}
        // Initialiser le graphique
        const ctx = document.getElementById('mileageChart').getContext('2d');
        const graphData = {{ graphData| json_encode | raw
    }};

    // Préparer les données pour le graphique
    const labels = graphData.map(item => new Date(item.date).toLocaleDateString());
    const data = graphData.map(item => item.kilometrage);

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Kilométrage',
                data: data,
                borderColor: 'rgb(75, 192, 192)',
                backgroundColor: 'rgba(75, 192, 192, 0.2)',
                fill: true,
                tension: 0.1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                title: {
                    display: true,
                    text: 'Évolution du kilométrage'
                },
            },
            scales: {
                x: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Date'
                    }
                },
                y: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Kilométrage'
                    },
                    suggestedMin: Math.min(...data) - 100,
                    suggestedMax: Math.max(...data) + 100
                }
            }
        }
    });
    {% endif %}
    });
</script>
{% endblock %}
{% endblock %}