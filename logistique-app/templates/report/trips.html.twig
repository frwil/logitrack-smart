{% extends 'base.html.twig' %}

{% block title %}Voyages par période - Logistique App{% endblock %}

{% block stylesheets %}
{{ parent() }}
<!-- Inclure SheetJS (xlsx) pour l'export Excel -->
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<!-- Inclure jsPDF et html2canvas pour l'export PDF -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Voyages par période</h3>
                        <div class="card-actions">
                            <button class="btn btn-success" onclick="exportToExcel()">
                                <i class="fas fa-file-excel"></i> Excel
                            </button>
                            <button class="btn btn-danger" onclick="exportToPDF()">
                                <i class="fas fa-file-pdf"></i> PDF
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        {# Formulaire de filtrage #}
                        <form method="get" class="row g-3 mb-4">
                            <div class="col-md-3">
                                <label for="date_debut" class="form-label">Date début</label>
                                <input type="date" class="form-control" id="date_debut" name="date_debut" value="{{ selectedDateDebut }}">
                            </div>
                            <div class="col-md-3">
                                <label for="date_fin" class="form-label">Date fin</label>
                                <input type="date" class="form-control" id="date_fin" name="date_fin" value="{{ selectedDateFin }}">
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary me-2">Filtrer</button>
                                <a href="{{ path('app_report_trips') }}" class="btn btn-secondary">Réinitialiser</a>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-vcenter table-mobile-md card-table" id="trips-table">
                                <thead>
                                    <tr>
                                        <th>Véhicule</th>
                                        <th>Destination</th>
                                        <th>Date voyage</th>
                                        <th>Date retour prévue</th>
                                        <th>Type de chargement</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for trip in trips %}
                                    {% set firstVoyageVehicule = trip.voyageVehicules.first() %}
                                    {% set isCompleted = trip.datePrevueVoyage is not null and trip.datePrevueVoyage < date() %}
                                    {% set isInProgress = trip.datePrevueVoyage is null or trip.datePrevueVoyage > date() %}
                                    
                                    <tr>
                                        <td>
                                            {% if trip.affectation and trip.affectation.idVehicule %}
                                                {{ trip.affectation.idVehicule.immatriculationVehicule }}
                                            {% else %}
                                                <span class="text-muted">Non assigné</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if firstVoyageVehicule and firstVoyageVehicule.destination %}
                                                {{ firstVoyageVehicule.destination.libelle }}
                                            {% else %}
                                                <span class="text-muted">Non spécifiée</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ trip.dateVoyage|date('d/m/Y H:i') }}</td>
                                        <td>
                                            {% if trip.datePrevueVoyage %}
                                                {{ trip.datePrevueVoyage|date('d/m/Y H:i') }}
                                            {% else %}
                                                <span class="text-muted">Non spécifiée</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if trip.typeChargement %}
                                                {{ trip.typeChargement.libelle }}
                                            {% else %}
                                                <span class="text-muted">Non spécifié</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if isCompleted %}
                                                <span class="badge text-bg-success">Terminé</span>
                                            {% elseif isInProgress %}
                                                <span class="badge text-bg-warning">En cours</span>
                                            {% else %}
                                                <span class="badge bg-secondary">Planifié</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center">Aucun voyage trouvé</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Fonction pour exporter en Excel
function exportToExcel() {
    // Sélectionner le tableau
    const table = document.getElementById('trips-table');
    
    // Cloner le tableau pour ne pas affecter l'affichage original
    const clonedTable = table.cloneNode(true);
    
    // Remplacer les badges par du texte simple pour Excel
    const statusCells = clonedTable.querySelectorAll('td:last-child');
    statusCells.forEach(cell => {
        if (cell.querySelector('.badge')) {
            cell.textContent = cell.querySelector('.badge').textContent;
        }
    });
    
    // Convertir le tableau en feuille de calcul
    const wb = XLSX.utils.table_to_book(clonedTable, {sheet: "Voyages"});
    
    // Exporter le fichier Excel
    XLSX.writeFile(wb, 'voyages_' + new Date().toISOString().slice(0, 10) + '.xlsx');
}

// Fonction pour exporter en PDF
function exportToPDF() {
    // Sélectionner le tableau
    const table = document.getElementById('trips-table');
    
    // Cloner le tableau pour ne pas affecter l'affichage original
    const clonedTable = table.cloneNode(true);
    
    // Appliquer des styles spécifiques pour l'impression PDF
    clonedTable.style.width = '100%';
    clonedTable.style.fontSize = '10px';
    
    // Créer un conteneur temporaire pour le tableau
    const tempContainer = document.createElement('div');
    tempContainer.style.position = 'absolute';
    tempContainer.style.left = '-9999px';
    tempContainer.appendChild(clonedTable);
    document.body.appendChild(tempContainer);
    
    // Utiliser html2canvas pour capturer le tableau
    html2canvas(clonedTable).then(canvas => {
        // Créer un nouveau document PDF
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('landscape', 'pt', 'a4');
        
        // Ajouter le titre
        doc.setFontSize(16);
        doc.text('Voyages par période', 40, 40);
        
        // Ajouter la date d'export
        doc.setFontSize(10);
        doc.text('Exporté le: ' + new Date().toLocaleDateString(), 40, 60);
        
        // Ajouter l'image du tableau
        const imgData = canvas.toDataURL('image/png');
        const imgWidth = doc.internal.pageSize.getWidth() - 80;
        const imgHeight = (canvas.height * imgWidth) / canvas.width;
        
        doc.addImage(imgData, 'PNG', 40, 70, imgWidth, imgHeight);
        
        // Sauvegarder le PDF
        doc.save('voyages_' + new Date().toISOString().slice(0, 10) + '.pdf');
        
        // Nettoyer le conteneur temporaire
        document.body.removeChild(tempContainer);
    });
}
</script>
{% endblock %}