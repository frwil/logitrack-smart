{# templates/report/maintenance_ongoing.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Réparations en cours - Logistique App{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Styles spécifiques pour la vue des réparations en cours */
    .ongoing-badge {
        background-color: #ffc107;
        color: #000;
    }
</style>
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Réparations en cours</h3>
                        <div class="card-actions">
                            <a href="{{ path('app_report_maintenance_costs') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour aux coûts de maintenance
                            </a>
                            <button class="btn btn-primary" onclick="window.print()">
                                <i class="fas fa-print"></i> Imprimer
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-vcenter table-mobile-md card-table" id="ongoingMaintenanceTable">
                                <thead>
                                    <tr>
                                        <th>Véhicule</th>
                                        <th>Marque/Modèle</th>
                                        <th>Type d'intervention</th>
                                        <th>Date d'entrée</th>
                                        <th>Coût total estimé</th>
                                        <th>Prestataire</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for cost in maintenanceCosts %}
                                    <tr>
                                        <td>{{ cost.affectation.idVehicule.immatriculationVehicule }}</td>
                                        <td>{{ cost.affectation.idVehicule.idMarque.nomMarque }} {{ cost.affectation.idVehicule.modeleVehicule.nomModele }}</td>
                                        <td>{{ cost.typeExecution ? 'Interne' : 'Externe' }}</td>
                                        <td>{{ cost.dateEntree|date('d/m/Y') }}</td>
                                        <td>{{ (cost.montantReparation + cost.plusOuMoinsValueValeur)|number_format(2, ',', ' ') }} FCFA</td>
                                        <td>{{ cost.prestataire.nom }}</td>
                                        <td>
                                            <a href="{{ path('app_bon_reparation_show', {'id': cost.id}) }}" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i> Détails
                                            </a>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center">Aucune réparation en cours</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Initialiser DataTable
        $('#ongoingMaintenanceTable').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
            },
            pageLength: 25,
            order: [[3, 'desc']]
        });
    });
</script>
{% endblock %}