{% extends 'base.html.twig' %}

{% block title %}Consommation de carburant - Logistique App{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .consumption-badge {
        font-size: 0.85rem;
        padding: 0.35em 0.65em;
    }

    .card-sm {
        transition: all 0.2s ease;
    }

    .card-sm:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }
    
    .chart-container {
        position: relative;
        height: 400px;
        margin-bottom: 20px;
    }

    @media (max-width: 768px) {
        .filter-section .col-md-4 {
            margin-bottom: 15px;
        }
        
        .chart-container {
            height: 300px;
        }
    }
    
    .dt-buttons {
        margin-bottom: 15px;
    }
    
    .dt-buttons .btn {
        margin-right: 5px;
    }
</style>
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Consommation de carburant</h3>
                        <div class="card-actions">
                            
                        </div>
                    </div>
                    <div class="card-body">
                        {# Filtres #}
                        <form method="get" action="{{ path('app_report_fuel_consumption') }}">
                            <div class="row mb-4 filter-section">
                                <div class="col-md-4">
                                    <label for="date_debut" class="form-label">Date de début</label>
                                    <input type="text" class="form-control datepicker" id="date_debut" name="date_debut" 
                                           value="{{ dateDebut }}" placeholder="Sélectionner une date">
                                </div>
                                <div class="col-md-4">
                                    <label for="date_fin" class="form-label">Date de fin</label>
                                    <input type="text" class="form-control datepicker" id="date_fin" name="date_fin" 
                                           value="{{ dateFin }}" placeholder="Sélectionner une date">
                                </div>
                                <div class="col-md-4">
                                    <label for="affectation" class="form-label">Affectation</label>
                                    <select class="form-select" id="affectation" name="affectation">
                                        <option value="">Toutes les affectations</option>
                                        {% for affectation in affectations %}
                                            <option value="{{ affectation.id }}" 
                                                    {{ selectedAffectation == affectation.id ? 'selected' : '' }}>
                                                {{ affectation.idVehicule.immatriculationVehicule }} - {{ affectation.idEntite.libelle }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-12 mt-3">
                                    <button type="submit" class="btn btn-primary">Filtrer</button>
                                    <a href="{{ path('app_report_fuel_consumption') }}" class="btn btn-secondary">Réinitialiser</a>
                                </div>
                            </div>
                        </form>

                        {# Statistiques récapitulatives #}
                        {% if fuelConsumption %}
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="card card-sm">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-primary text-white avatar">
                                                    <i class="fas fa-gas-pump"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ fuelConsumption.total_carburant|default(0)|number_format(2, ',', ' ') }} L
                                                </div>
                                                <div class="text-muted">
                                                    Carburant total
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card card-sm">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-success text-white avatar">
                                                    <i class="fas fa-road"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ fuelConsumption.total_distance|default(0)|number_format(0, ',', ' ') }} km
                                                </div>
                                                <div class="text-muted">
                                                    Distance totale
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card card-sm">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-info text-white avatar">
                                                    <i class="fas fa-tachometer-alt"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ fuelConsumption.consommation_moyenne|default(0)|number_format(2, ',', ' ') }} L/100km
                                                </div>
                                                <div class="text-muted">
                                                    Consommation moyenne
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endif %}

                        {# Graphique d'évolution de la consommation #}
                        <div class="card mb-4">
                            <div class="card-header">
                                <h4 class="card-title">Évolution de la consommation</h4>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="consumptionChart"></canvas>
                                </div>
                            </div>
                        </div>

                        {# Tableau des données #}
                        <div class="table-responsive">
                            <table class="table table-vcenter table-mobile-md card-table" id="fuelConsumptionTable">
                                <thead>
                                    <tr>
                                        <th>Véhicule</th>
                                        <th>Dernier plein</th>
                                        <th>Volume (L)</th>
                                        <th>Coût</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for vehicleId, fillUp in lastFillUps %}
                                    <tr>
                                        <td>{{ fillUp.vehicule.immatriculation_vehicule }}</td>
                                        <td>{{ fillUp.date|date('d/m/Y') }}</td>
                                        <td>{{ fillUp.volume|number_format(2, ',', ' ') }}</td>
                                        <td>{{ fillUp.cout|number_format(2, ',', ' ') }} €</td>
                                        <td>
                                            {% set daysSinceLastFill = date().diff(date(fillUp.date)).days %}
                                            <span class="badge {% if daysSinceLastFill < 7 %}bg-success{% elseif daysSinceLastFill < 14 %}bg-warning{% else %}bg-danger{% endif %}">
                                                {{ daysSinceLastFill }} jour(s)
                                            </span>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Initialiser les datepickers
        flatpickr('.datepicker', {
            locale: 'fr',
            dateFormat: 'd/m/Y',
        });

        // Initialiser DataTable avec les boutons d'export
        $('#fuelConsumptionTable').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
            },
            dom: 'Bfrtip',
            buttons: [
                {
                    extend: 'excel',
                    text: 'Exporter en Excel',
                    className: 'btn btn-success mb-3',
                    title: 'Consommation Carburant - {{ "now"|date("d/m/Y") }}',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4]
                    }
                },
                {
                    extend: 'pdf',
                    text: 'Exporter en PDF',
                    className: 'btn btn-danger mb-3',
                    title: 'Consommation Carburant - {{ "now"|date("d/m/Y") }}',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4]
                    },
                    customize: function (doc) {
                        doc.content[1].table.widths = ['*', '*', '*', '*', '*'];
                        doc.styles.tableHeader.alignment = 'center';
                        doc.content[1].table.body.forEach(function(row) {
                            row.forEach(function(cell) {
                                cell.alignment = 'center';
                            });
                        });
                    }
                }
            ],
            pageLength: 25,
            order: [[1, 'desc']],
            responsive: true
        });

        // Données pour le graphique (données réelles)
        const consumptionData = {
            labels: [{% for data in consumptionEvolution %}'{{ data.date }}'{% if not loop.last %}, {% endif %}{% endfor %}],
            datasets: [
                {
                    label: 'Consommation (L/100km)',
                    data: [{% for data in consumptionEvolution %}{{ data.consommation_moyenne|default(0)|number_format(2, '.', '') }}{% if not loop.last %}, {% endif %}{% endfor %}],
                    borderColor: 'rgb(54, 162, 235)',
                    backgroundColor: 'rgba(54, 162, 235, 0.1)',
                    tension: 0.3,
                    fill: true,
                    yAxisID: 'y'
                },
                {
                    label: 'Carburant total (L)',
                    data: [{% for data in consumptionEvolution %}{{ data.total_carburant|default(0)|number_format(2, '.', '') }}{% if not loop.last %}, {% endif %}{% endfor %}],
                    borderColor: 'rgb(255, 99, 132)',
                    backgroundColor: 'rgba(255, 99, 132, 0.1)',
                    tension: 0.3,
                    fill: true,
                    yAxisID: 'y1',
                    hidden: true
                }
            ]
        };

        // Configuration du graphique
        const config = {
            type: 'line',
            data: consumptionData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Évolution de la consommation de carburant'
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false
                    },
                    legend: {
                        position: 'top',
                    }
                },
                scales: {
                    y: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        title: {
                            display: true,
                            text: 'Consommation (L/100km)'
                        }
                    },
                    y1: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        title: {
                            display: true,
                            text: 'Carburant total (L)'
                        },
                        grid: {
                            drawOnChartArea: false,
                        },
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Date'
                        }
                    }
                }
            }
        };

        // Initialisation du graphique
        const consumptionChart = new Chart(
            document.getElementById('consumptionChart'),
            config
        );
    });
</script>
{% endblock %}