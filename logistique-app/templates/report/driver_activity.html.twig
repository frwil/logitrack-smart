{% extends 'base.html.twig' %}

{% block title %}Activité des chauffeurs - Logistique App{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .stat-card {
        transition: all 0.2s ease;
    }
    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }
    .chart-container {
        position: relative;
        height: 400px;
        margin-bottom: 20px;
    }
</style>
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Activité des chauffeurs</h3>
                        <div class="card-actions">
                            
                        </div>
                    </div>
                    <div class="card-body">
                        {# Filtres #}
                        <form method="get" action="{{ path('app_report_driver_activity') }}">
                            <div class="row mb-4">
                                <div class="col-md-3">
                                    <label for="date_debut" class="form-label">Date de début</label>
                                    <input type="text" class="form-control datepicker" id="date_debut" name="date_debut" 
                                           value="{{ selectedDateDebut }}" placeholder="jj/mm/aaaa">
                                </div>
                                <div class="col-md-3">
                                    <label for="date_fin" class="form-label">Date de fin</label>
                                    <input type="text" class="form-control datepicker" id="date_fin" name="date_fin" 
                                           value="{{ selectedDateFin }}" placeholder="jj/mm/aaaa">
                                </div>
                                <div class="col-md-3">
                                    <label for="statut" class="form-label">Statut</label>
                                    <select class="form-select" id="statut" name="statut">
                                        <option value="">Tous</option>
                                        <option value="actif" {{ selectedStatut == 'actif' ? 'selected' : '' }}>Actif</option>
                                        <option value="inactif" {{ selectedStatut == 'inactif' ? 'selected' : '' }}>Inactif</option>
                                    </select>
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary">Filtrer</button>
                                    <a href="{{ path('app_report_driver_activity') }}" class="btn btn-secondary ms-2">Réinitialiser</a>
                                </div>
                            </div>
                        </form>

                        {# Statistiques récapitulatives #}
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="card card-sm stat-card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-primary text-white avatar">
                                                    <i class="fas fa-users"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ totalChauffeurs }} chauffeurs
                                                </div>
                                                <div class="text-muted">
                                                    Total
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card card-sm stat-card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-success text-white avatar">
                                                    <i class="fas fa-user-check"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ chauffeursActifs }} actifs
                                                </div>
                                                <div class="text-muted">
                                                    Chauffeurs actifs
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card card-sm stat-card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-danger text-white avatar">
                                                    <i class="fas fa-user-times"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ chauffeursInactifs }} inactifs
                                                </div>
                                                <div class="text-muted">
                                                    Chauffeurs inactifs
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card card-sm stat-card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <span class="bg-info text-white avatar">
                                                    <i class="fas fa-road"></i>
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="font-weight-medium">
                                                    {{ totalKilometrage|number_format(0, ',', ' ') }} km
                                                </div>
                                                <div class="text-muted">
                                                    Kilométrage total
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Graphique #}
                        <div class="card mb-4">
                            <div class="card-header">
                                <h4 class="card-title">Répartition des kilomètres par chauffeur</h4>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="driverChart"></canvas>
                                </div>
                            </div>
                        </div>

                        {# Tableau des données #}
                        <div class="table-responsive">
                            <table class="table table-vcenter table-mobile-md card-table" id="driverActivityTable">
                                <thead>
                                    <tr>
                                        <th>Chauffeur</th>
                                        <th>Nombre de voyages</th>
                                        <th>Kilométrage total</th>
                                        <th>Dernière activité</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for driver in driverActivity %}
                                    <tr>
                                        <td>{{ driver.chauffeur.prenom }} {{ driver.chauffeur.nom }}</td>
                                        <td>{{ driver.nombreVoyages }}</td>
                                        <td>{{ driver.kilometrageTotal|number_format(0, ',', ' ') }} km</td>
                                        <td>
                                            {% if driver.dernierVoyage %}
                                                {{ driver.dernierVoyage|date('d/m/Y') }}
                                            {% else %}
                                                <span class="text-muted">N/A</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if driver.chauffeur.estActif %}
                                                <span class="badge text-bg-success">Actif</span>
                                            {% else %}
                                                <span class="badge text-bg-danger">Inactif</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center">Aucune activité de chauffeur trouvée</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Initialiser les datepickers
        flatpickr('.datepicker', {
            locale: 'fr',
            dateFormat: 'd/m/Y',
        });

        // Initialiser DataTable avec les boutons d'export
        $('#driverActivityTable').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
            },
            dom: 'Bfrtip',
            buttons: [
                {
                    extend: 'excel',
                    text: 'Exporter en Excel',
                    className: 'btn btn-success mb-3',
                    title: 'Activité des chauffeurs - {{ "now"|date("d/m/Y") }}',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4]
                    }
                },
                {
                    extend: 'pdf',
                    text: 'Exporter en PDF',
                    className: 'btn btn-danger mb-3',
                    title: 'Activité des chauffeurs - {{ "now"|date("d/m/Y") }}',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4]
                    },
                    customize: function (doc) {
                        doc.content[1].table.widths = ['*', '*', '*', '*', '*'];
                        doc.styles.tableHeader.alignment = 'center';
                        doc.content[1].table.body.forEach(function(row) {
                            row.forEach(function(cell) {
                                cell.alignment = 'center';
                            });
                        });
                    }
                }
            ],
            pageLength: 25,
            order: [[2, 'desc']] // Trier par kilométrage total décroissant par défaut
        });

        // Données pour le graphique
        const driverData = {
            labels: [{% for driver in driverActivity %}'{{ driver.chauffeur.prenom }} {{ driver.chauffeur.nom }}'{% if not loop.last %}, {% endif %}{% endfor %}],
            datasets: [{
                data: [{% for driver in driverActivity %}{{ driver.kilometrageTotal }}{% if not loop.last %}, {% endif %}{% endfor %}],
                backgroundColor: [
                    'rgb(255, 99, 132)',
                    'rgb(54, 162, 235)',
                    'rgb(255, 205, 86)',
                    'rgb(75, 192, 192)',
                    'rgb(153, 102, 255)',
                    'rgb(255, 159, 64)',
                    'rgb(201, 203, 207)',
                    'rgb(0, 162, 235)',
                    'rgb(255, 105, 86)',
                    'rgb(75, 192, 92)'
                ]
            }]
        };

        // Configuration du graphique
        const config = {
            type: 'pie',
            data: driverData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.label + ': ' + context.raw.toLocaleString() + ' km';
                            }
                        }
                    }
                }
            }
        };

        // Initialisation du graphique
        const driverChart = new Chart(
            document.getElementById('driverChart'),
            config
        );
    });
</script>
{% endblock %}