{% extends 'base.html.twig' %}

{% block title %}Liste des Prestataires d'Intervention{% endblock %}

{% block stylesheets %}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Prestataires d'Intervention</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_prestataire_intervention_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Nouveau Prestataire</span>
                                <i class="fas fa-plus d-sm-none"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="prestataire-table" class="table card-table table-vcenter text-nowrap datatable">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nom</th>
                                        <th>Contact</th>
                                        <th>Téléphone</th>
                                        <th>Email</th>
                                        <th>Spécialités</th>
                                        <th>Nombre d'interventions</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for prestataire in prestataire_interventions %}
                                    <tr>
                                        <td>{{ prestataire.id }}</td>
                                        <td>{{ prestataire.nom }}</td>
                                        <td>{{ prestataire.contact|default('N/A') }}</td>
                                        <td>{{ prestataire.telephone|default('N/A') }}</td>
                                        <td>{{ prestataire.email|default('N/A') }}</td>
                                        <td>
                                            {% if prestataire.specialites %}
                                                {% if prestataire.specialites|length > 30 %}
                                                    {{ prestataire.specialites|slice(0, 30) }}...
                                                {% else %}
                                                    {{ prestataire.specialites }}
                                                {% endif %}
                                            {% else %}
                                                N/A
                                            {% endif %}
                                        </td>
                                        <td>{{ prestataire.nombreInterventions }}</td>
                                        <td>
                                            {% if prestataire.actif %}
                                            <span class="badge text-bg-success">Actif</span>
                                            {% else %}
                                            <span class="badge text-bg-danger">Inactif</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_prestataire_intervention_show', {'id': prestataire.id}) }}"
                                                class="btn btn-icon btn-sm" title="Détails">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_prestataire_intervention_edit', {'id': prestataire.id}) }}"
                                                class="btn btn-icon btn-sm" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                            <form method="post"
                                                action="{{ path('app_prestataire_intervention_delete', {'id': prestataire.id}) }}"
                                                onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce prestataire ?');"
                                                class="d-inline">
                                                <input type="hidden" name="_token"
                                                    value="{{ csrf_token('delete' ~ prestataire.id) }}">
                                                <button type="submit" class="btn btn-icon btn-sm text-danger"
                                                    title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function () {
        $('#prestataire-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            },
            order: [[1, 'asc']],
            responsive: true,
            columnDefs: [
                { responsivePriority: 1, targets: 1 },
                { responsivePriority: 2, targets: -1 }
            ]
        });
    });
</script>
{% endblock %}