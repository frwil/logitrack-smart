{% extends 'base.html.twig' %}

{% block title %}Nouveau type de document{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Nouveau type de document</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_type_document_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>
                                Retour à la liste
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="mb-3">
                                <label for="nom" class="form-label">Nom du type de document</label>
                                <input type="text" class="form-control" id="nom" name="nom" required placeholder="Ex: Carte grise, Assurance, Contrôle technique...">
                            </div>
                            <div class="mb-3">
                                <label for="validite" class="form-label">Validité (en mois)</label>
                                <input type="number" class="form-control" id="validite" name="validite" value="0" min="0" placeholder="0 pour aucune expiration">
                                <div class="form-text">Nombre de mois avant expiration (0 = pas d'expiration)</div>
                            </div>
                            <div class="form-footer">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>
                                    Créer
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}