{% extends 'base.html.twig' %}

{% block title %}Types de documents{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Types de documents</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_type_document_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>
                                Nouveau type
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                    <tr>
                                        <th>Nom</th>
                                        <th>Validité (mois)</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for type_document in type_documents %}
                                    <tr>
                                        <td>{{ type_document.nom }}</td>
                                        <td>{{ type_document.validite }}</td>
                                        <td>
                                            <a href="{{ path('app_type_document_show', {'id': type_document.id}) }}" class="btn btn-icon btn-sm" title="Voir">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_type_document_edit', {'id': type_document.id}) }}" class="btn btn-icon btn-sm" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form method="post" action="{{ path('app_type_document_delete', {'id': type_document.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce type de document ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type_document.id) }}">
                                                <button type="submit" class="btn btn-icon btn-sm text-danger" title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center">Aucun type de document trouvé</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}