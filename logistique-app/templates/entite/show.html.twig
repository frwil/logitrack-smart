{% extends 'base.html.twig' %}

{% block title %}Détails de l'entité - {{ entite.libelle }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Détails de l'entité</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_entite_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>
                                Retour à la liste
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5 class="text-muted">Libellé</h5>
                                <p class="fs-4">{{ entite.libelle }}</p>
                            </div>
                            <div class="col-md-6">
                                <h5 class="text-muted">Statut</h5>
                                <p>
                                    {% if entite.statut %}
                                        <span class="badge text-bg-success">Actif</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary">Inactif</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <h5 class="text-muted">Description</h5>
                                <p class="fs-6">{{ entite.description ?? 'Aucune description' }}</p>
                            </div>
                        </div>
                        <div class="mt-4">
                            <a href="{{ path('app_entite_edit', {'id': entite.id}) }}" class="btn btn-primary me-2">
                                <i class="fas fa-edit me-2"></i>
                                Modifier
                            </a>
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                <form method="post" action="{{ path('app_entite_delete', {'id': entite.id}) }}" 
                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette entité ?');" 
                                      class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entite.id) }}">
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-trash me-2"></i>
                                        Supprimer
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}