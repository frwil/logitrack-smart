{% extends 'base.html.twig' %}

{% block title %}Détails de la Marque - {{ marque.nomMarque }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Détails de la marque</h3>
                            <div class="ms-auto">
                                <a href="{{ path('app_marque_vehicule_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Retour à la liste
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <h5 class="text-muted">Nom</h5>
                                    <p class="fs-4">{{ marque.nomMarque }}</p>
                                </div>
                                <div class="col-md-6">
                                    <h5 class="text-muted">Nombre de véhicules</h5>
                                    <p class="fs-4">
                                        <span class="badge text-bg-primary">{{ marque.vehicules|length }}</span>
                                    </p>
                                </div>
                            </div>

                            {% if marque.vehicules|length > 0 %}
                            <div class="row">
                                <div class="col-12">
                                    <h5 class="text-muted">Véhicules de cette marque</h5>
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Immatriculation</th>
                                                    <th>Modèle</th>
                                                    <th>Statut</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for vehicule in marque.vehicules|slice(0, 5) %}
                                                <tr>
                                                    <td>{{ vehicule.immatriculationVehicule }}</td>
                                                    <td><a
                                                            href="{{ path('app_modele_vehicule_show', {'id': marque.id}) }}">
                                                            {{ vehicule.modeleVehicule.nomModele }}
                                                        </a></td>
                                                    <td>
                                                        {% if vehicule.affectationVehicules|length > 0 and
                                                        vehicule.affectationVehicules|last.dateFinAffectation is null %}
                                                        <span class="badge text-bg-success">Affecté</span>
                                                        {% else %}
                                                        <span class="badge text-bg-secondary">Disponible</span>
                                                        {% endif %}
                                                    </td>
                                                </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                    {% if marque.vehicules|length > 5 %}
                                    <p class="text-muted mt-2">... et {{ marque.vehicules|length - 5 }} autres véhicules
                                    </p>
                                    {% endif %}
                                </div>
                            </div>
                            {% endif %}
                        </div>
                        <div class="card-footer d-flex">
                            <a href="{{ path('app_marque_vehicule_edit', {'id': marque.id}) }}"
                                class="btn btn-primary me-2">
                                <i class="fas fa-edit me-2"></i>
                                Modifier
                            </a>
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                            <form method="post" action="{{ path('app_marque_vehicule_delete', {'id': marque.id}) }}"
                                onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette marque ?');"
                                class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ marque.id) }}">
                                <button type="submit" class="btn btn-danger me-2">
                                    <i class="fas fa-trash me-2"></i>
                                    Supprimer
                                </button>
                            </form>
                            {% endif %}
                            <a href="{{ path('app_marque_vehicule_index') }}" class="btn btn-secondary">
                                <i class="fas fa-list me-2"></i>
                                Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% endblock %}