{% extends 'base.html.twig' %}

{% block title %}Créer une nouvelle marque de véhicule{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Créer une nouvelle marque de véhicule</h3>
                            <div class="ms-auto">
                                <a href="{{ path('app_marque_vehicule_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Retour à la liste
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <form method="post" class="needs-validation" novalidate>
                                <input type="hidden" name="_token" value="{{ csrf_token('marque_new') }}">
                                
                                <div class="row">
                                    <div class="col-12">
                                        <div class="mb-3">
                                            <label class="form-label" for="nom">Nom de la marque</label>
                                            <input type="text" class="form-control" id="nom_marque" name="nom_marque" required>
                                            <div class="invalid-feedback">
                                                Veuillez saisir un nom pour la marque.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-4">
                                    <button type="submit" class="btn btn-primary me-2">
                                        <i class="fas fa-save me-2"></i>
                                        Enregistrer
                                    </button>
                                    <a href="{{ path('app_marque_vehicule_index') }}" class="btn btn-secondary">
                                        <i class="fas fa-times me-2"></i>
                                        Annuler
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Validation Bootstrap du formulaire
        (function () {
            'use strict'
            
            var forms = document.querySelectorAll('.needs-validation')
            
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
{% endblock %}