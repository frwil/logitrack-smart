{% extends 'base.html.twig' %}

{% block title %}Liste des Marques de Véhicules{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-12">
                    <div class="card card-table">
                        <div class="card-header">
                            <h3 class="card-title">Marques de Véhicules</h3>
                            <div class="ms-auto">
                                <a href="{{ path('app_marque_vehicule_new') }}" class="btn btn-primary">
                                    <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                    <span class="d-none d-sm-inline-block">Nouvelle Marque</span>
                                    <i class="fas fa-plus d-sm-none"></i>
                                </a>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table id="marque-vehicule-table" class="table card-table table-vcenter text-nowrap datatable">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nom</th>
                                        <th>Nombre de véhicules</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for marque in marques %}
                                    <tr>
                                        <td>{{ marque.id }}</td>
                                        <td><a href="{{ path('app_marque_vehicule_show', {'id': marque.id}) }}">
                                                {{ marque.nomMarque }}
                                            </a></td>
                                        <td>
                                            <span class="badge text-bg-primary">{{ marque.vehicules|length }}</span>
                                        </td>
                                        <td>
                                            <a href="{{ path('app_marque_vehicule_show', {'id': marque.id}) }}" class="btn btn-icon btn-sm" title="Détails" aria-label="Voir détails de la marque">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_marque_vehicule_edit', {'id': marque.id}) }}" class="btn btn-icon btn-sm" title="Modifier" aria-label="Modifier la marque">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                                <form method="post" action="{{ path('app_marque_vehicule_delete', {'id': marque.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette marque ?');" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ marque.id) }}">
                                                    <button type="submit" class="btn btn-icon btn-sm text-danger" title="Supprimer" aria-label="Supprimer la marque">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center">Aucune marque trouvée.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {
            $('#marque-vehicule-table').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
                },
                order: [[1, 'asc']], // Tri par nom par défaut
                responsive: true,
                columnDefs: [
                    { responsivePriority: 1, targets: 1 }, // Priorité responsive pour le nom
                    { responsivePriority: 2, targets: -1 } // Priorité responsive pour les actions
                ]
            });
        });
    </script>
{% endblock %}