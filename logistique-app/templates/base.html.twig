    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Gestion du sidebar responsive
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const dropdownOverlay = document.getElementById('dropdownOverlay');
            const toggleBtn = document.getElementById('toggleSidebar');
            const closeBtn = document.getElementById('closeSidebar');

            function toggleSidebar() {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
                document.body.classList.toggle('sidebar-open');

                // Empêcher le défilement de la page lorsque le sidebar est ouvert
                if (sidebar.classList.contains('show')) {
                    document.body.style.overflow = 'hidden';
                } else {
                    document.body.style.overflow = '';
                }
            }

            if (toggleBtn) {
                toggleBtn.addEventListener('click', toggleSidebar);
            }

            if (closeBtn) {
                closeBtn.addEventListener('click', toggleSidebar);
            }

            if (overlay) {
                overlay.addEventListener('click', toggleSidebar);
            }

            // Fermer le sidebar uniquement quand on clique sur un sous-menu (dropdown-item)
            const dropdownItems = document.querySelectorAll('.navbar-vertical .dropdown-item');
            dropdownItems.forEach(item => {
                item.addEventListener('click', function () {
                    if (window.innerWidth < 1200) {
                        toggleSidebar();
                    }
                });
            });

            // Gestion spécifique des dropdowns de la sidebar en mode mobile
            const sidebarDropdownToggles = document.querySelectorAll('#sidebar .dropdown-toggle');

            sidebarDropdownToggles.forEach(toggle => {
                toggle.addEventListener('click', function (e) {
                    if (window.innerWidth < 1200) {
                        e.preventDefault();
                        e.stopPropagation();

                        const dropdownMenu = this.nextElementSibling;
                        const isShowing = dropdownMenu.classList.contains('show');

                        // Fermer tous les autres dropdowns de la sidebar
                        document.querySelectorAll('#sidebar .dropdown-menu.show').forEach(menu => {
                            if (menu !== dropdownMenu) {
                                menu.classList.remove('show');
                            }
                        });

                        // Ouvrir/fermer le dropdown actuel
                        if (!isShowing) {
                            dropdownMenu.classList.add('show');
                            this.setAttribute('aria-expanded', 'true');
                        } else {
                            dropdownMenu.classList.remove('show');
                            this.setAttribute('aria-expanded', 'false');
                        }
                    }
                });
            });

            // Fermer les dropdowns de la sidebar quand on clique en dehors sur mobile
            document.addEventListener('click', function (e) {
                if (window.innerWidth < 1200) {
                    if (!e.target.closest('#sidebar .dropdown')) {
                        document.querySelectorAll('#sidebar .dropdown-menu.show').forEach(menu => {
                            menu.classList.remove('show');
                        });
                        document.querySelectorAll('#sidebar .dropdown-toggle').forEach(toggle => {
                            toggle.setAttribute('aria-expanded', 'false');
                        });
                    }
                }
            });

            // Gestion des dropdowns sur mobile pour la navbar horizontale
            const dropdownToggles = document.querySelectorAll('header .dropdown-toggle');

            dropdownToggles.forEach(toggle => {
                toggle.addEventListener('click', function (e) {
                    if (window.innerWidth < 768) {
                        e.preventDefault();
                        e.stopPropagation();

                        const dropdownMenu = this.nextElementSibling;
                        const isShowing = dropdownMenu.classList.contains('show');

                        // Fermer tous les dropdowns
                        document.querySelectorAll('header .dropdown-menu.show').forEach(menu => {
                            menu.classList.remove('show');
                        });

                        // Cacher l'overlay
                        dropdownOverlay.classList.remove('show');

                        // Ouvrir le dropdown actuel s'il était fermé
                        if (!isShowing) {
                            dropdownMenu.classList.add('show');
                            dropdownOverlay.classList.add('show');
                        }
                    }
                });
            });

            // Fermer les dropdowns quand on clique sur l'overlay
            if (dropdownOverlay) {
                dropdownOverlay.addEventListener('click', function () {
                    document.querySelectorAll('.navbar .dropdown-menu.show').forEach(menu => {
                        menu.classList.remove('show');
                    });
                    this.classList.remove('show');
                });
            }

            // Adapter la navigation en fonction de la taille de l'écran
            function handleResize() {
                if (window.innerWidth >= 1200) {
                    sidebar.classList.remove('show');
                    overlay.classList.remove('show');
                    document.body.classList.remove('sidebar-open');
                    document.body.style.overflow = '';

                    // Fermer tous les dropdowns de la sidebar
                    document.querySelectorAll('#sidebar .dropdown-menu.show').forEach(menu => {
                        menu.classList.remove('show');
                    });
                    document.querySelectorAll('#sidebar .dropdown-toggle').forEach(toggle => {
                        toggle.setAttribute('aria-expanded', 'false');
                    });
                }

                // Fermer les dropdowns mobiles quand on redimensionne vers desktop
                if (window.innerWidth >= 768) {
                    document.querySelectorAll('.navbar .dropdown-menu.show').forEach(menu => {
                        menu.classList.remove('show');
                    });
                    dropdownOverlay.classList.remove('show');
                }
            }

            window.addEventListener('resize', handleResize);
            handleResize(); // Appel initial

            // S'assurer que le menu est toujours visible sur desktop
            if (window.innerWidth >= 1200) {
                const navbarMenu = document.getElementById('navbar-menu');
                if (navbarMenu) {
                    navbarMenu.classList.add('show');
                }
            }

            // Gestion du dropdown au survol pour desktop
            const dropdownVehicules = document.getElementById('dropdown-vehicules');
            const dropdownAffectations = document.getElementById('dropdown-affectations');
            const dropdownMaintenance = document.getElementById('dropdown-maintenance');
            const dropdownConfiguration = document.getElementById('dropdown-configuration');

            if (dropdownVehicules && window.innerWidth >= 1200) {
                const dropdownMenu = dropdownVehicules.querySelector('.dropdown-menu');

                dropdownVehicules.addEventListener('mouseenter', function () {
                    dropdownMenu.style.display = 'block';
                });

                dropdownVehicules.addEventListener('mouseleave', function () {
                    dropdownMenu.style.display = 'none';
                });
            }

            if (dropdownAffectations && window.innerWidth >= 1200) {
                const dropdownMenu = dropdownAffectations.querySelector('.dropdown-menu');

                dropdownAffectations.addEventListener('mouseenter', function () {
                    dropdownMenu.style.display = 'block';
                });

                dropdownAffectations.addEventListener('mouseleave', function () {
                    dropdownMenu.style.display = 'none';
                });
            }

            if (dropdownMaintenance && window.innerWidth >= 1200) {
                const dropdownMenu = dropdownMaintenance.querySelector('.dropdown-menu');

                dropdownMaintenance.addEventListener('mouseenter', function () {
                    dropdownMenu.style.display = 'block';
                });

                dropdownMaintenance.addEventListener('mouseleave', function () {
                    dropdownMenu.style.display = 'none';
                });
            }

            if (dropdownConfiguration && window.innerWidth >= 1200) {
                const dropdownMenu = dropdownConfiguration.querySelector('.dropdown-menu');

                dropdownConfiguration.addEventListener('mouseenter', function () {
                    dropdownMenu.style.display = 'block';
                });

                dropdownConfiguration.addEventListener('mouseleave', function () {
                    dropdownMenu.style.display = 'none';
                });
            }

            // Amélioration de l'expérience des dropdowns de la barre horizontale
            const horizontalDropdowns = document.querySelectorAll('header .dropdown');

            horizontalDropdowns.forEach(dropdown => {
                const toggle = dropdown.querySelector('.dropdown-toggle');
                const menu = dropdown.querySelector('.dropdown-menu');

                if (toggle && menu) {
                    // Ouvrir le dropdown au clic
                    toggle.addEventListener('click', function (e) {
                        if (window.innerWidth >= 768) {
                            e.preventDefault();
                            e.stopPropagation();

                            // Fermer tous les autres dropdowns
                            document.querySelectorAll('header .dropdown-menu').forEach(m => {
                                if (m !== menu) {
                                    m.classList.remove('show');
                                }
                            });

                            // Basculer l'état du dropdown actuel
                            menu.classList.toggle('show');
                        }
                    });

                    // Garder le dropdown ouvert lors du survol
                    dropdown.addEventListener('mouseenter', function () {
                        if (window.innerWidth >= 768) {
                            menu.classList.add('show');
                        }
                    });

                    dropdown.addEventListener('mouseleave', function () {
                        if (window.innerWidth >= 768) {
                            // Petit délai avant de fermer pour permettre à l'utilisateur de revenir
                            setTimeout(() => {
                                if (!dropdown.matches(':hover')) {
                                    menu.classList.remove('show');
                                }
                            }, 300);
                        }
                    });
                }
            });

            // Fermer les dropdowns en cliquant à l'extérieur
            document.addEventListener('click', function (e) {
                if (window.innerWidth >= 768) {
                    if (!e.target.closest('header .dropdown')) {
                        document.querySelectorAll('header .dropdown-menu').forEach(menu => {
                            menu.classList.remove('show');
                        });
                    }
                }
            });

            // Recherche AJAX avec suggestions en temps réel
            const searchInput = document.getElementById('searchInput');
            const searchResults = document.getElementById('searchResults');
            let searchTimeout = null;
            let currentPage = 1;
            let currentQuery = '';

            if (searchInput && searchResults) {
                // Écouter les changements de saisie
                searchInput.addEventListener('input', function (e) {
                    clearTimeout(searchTimeout);
                    const query = e.target.value.trim();

                    if (query.length < 2) {
                        searchResults.style.display = 'none';
                        return;
                    }

                    searchTimeout = setTimeout(() => {
                        currentQuery = query;
                        currentPage = 1;
                        performSearch(query, 1);
                    }, 300);
                });

                // Gérer la soumission du formulaire
                const searchForm = document.getElementById('searchForm');
                if (searchForm) {
                    searchForm.addEventListener('submit', function (e) {
                        if (currentQuery) {
                            e.preventDefault();
                            window.location.href = "{{ path('app_search') }}?q=" + encodeURIComponent(currentQuery);
                        }
                    });
                }

                // Fermer les résultats quand on clique ailleurs
                document.addEventListener('click', function (e) {
                    if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                        searchResults.style.display = 'none';
                    }
                });
            }

            function performSearch(query, page) {
                searchResults.innerHTML = '<div class="search-loading"><i class="fas fa-spinner fa-spin"></i> Recherche en cours...</div>';
                searchResults.style.display = 'block';

                fetch('{{ path("app_search_ajax") }}?q=' + encodeURIComponent(query) + '&page=' + page)
                    .then(response => response.json())
                    .then(data => {
                        displayResults(data, query);
                    })
                    .catch(error => {
                        searchResults.innerHTML = '<div class="search-no-results">Erreur lors de la recherche</div>';
                    });
            }

            function displayResults(data, query) {
                if (data.results.length === 0) {
                    searchResults.innerHTML = '<div class="search-no-results">Aucun résultat trouvé</div>';
                    return;
                }

                let html = '';

                // Afficher les résultats
                data.results.forEach(result => {
                    html += `
                        <div class="search-result-item" data-url="${result.url}">
                            <div>
                                <div>${highlightMatches(result.title, query)}</div>
                                <div class="small text-muted">${highlightMatches(result.description, query)}</div>
                            </div>
                            <div class="search-result-category">${result.category}</div>
                        </div>
                    `;
                });

                // Ajouter la pagination si nécessaire
                if (data.totalPages > 1) {
                    html += `<div class="search-pagination">`;
                    if (currentPage > 1) {
                        html += `<button class="btn btn-sm btn-outline-primary me-1" onclick="searchPage(${currentPage - 1})">Précédent</button>`;
                    }
                    html += `<span class="mx-2">Page ${currentPage} / ${data.totalPages}</span>`;
                    if (currentPage < data.totalPages) {
                        html += `<button class="btn btn-sm btn-outline-primary ms-1" onclick="searchPage(${currentPage + 1})">Suivant</button>`;
                    }
                    html += `</div>`;
                }

                searchResults.innerHTML = html;

                // Ajouter les événements de clic sur les résultats
                document.querySelectorAll('.search-result-item').forEach(item => {
                    item.addEventListener('click', function () {
                        window.location.href = this.dataset.url;
                    });
                });
            }

            function highlightMatches(text, query) {
                if (!text) return '';

                const regex = new RegExp(query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');
                return text.replace(regex, match => `<span class="search-highlight">${match}</span>`);
            }

            // Fonction globale pour la pagination
            window.searchPage = function (page) {
                currentPage = page;
                performSearch(currentQuery, page);

                // Scroll to top of results
                searchResults.scrollTop = 0;
            };
        });
        document.addEventListener('DOMContentLoaded', function () {
            {% if app.user %}
            const notificationDropdown = document.getElementById('notificationDropdown');
            const notificationBadge = document.getElementById('notificationBadge');
            const notificationList = document.getElementById('notificationList');
            const markAllAsRead = document.getElementById('markAllAsRead');

            // Charger les notifications
            function loadNotifications() {
                fetch("{{ path('app_notification_ajax') }}")
                    .then(response => response.json())
                    .then(data => {
                        if (data.count > 0) {
                            notificationBadge.textContent = data.count;
                            notificationBadge.classList.remove('d-none');

                            let html = '';
                            data.notifications.forEach(notif => {
                                html += `
                            <div class="list-group-item notification-item" data-id="${notif.id}">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <span class="status-dot status-dot-animated bg-${notif.type} d-block"></span>
                                    </div>
                                    <div class="col text-truncate">
                                        <a href="${notif.link || '#'}" class="text-body d-block">${notif.message}</a>
                                        <div class="d-block text-muted text-truncate mt-n1">${notif.createdAt}</div>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-sm btn-icon mark-as-read" data-id="${notif.id}">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `;
                            });

                            notificationList.innerHTML = html;

                            // Ajouter les événements pour marquer comme lu
                            document.querySelectorAll('.mark-as-read').forEach(btn => {
                                btn.addEventListener('click', function (e) {
                                    e.preventDefault();
                                    const id = this.dataset.id;
                                    markNotificationAsRead(id);
                                });
                            });
                        } else {
                            notificationBadge.classList.add('d-none');
                            notificationList.innerHTML = `
                        <div class="list-group-item">
                            <div class="row align-items-center">
                                <div class="col text-center text-muted py-3">
                                    <i class="fas fa-bell-slash fa-2x mb-2"></i>
                                    <p>Aucune notification</p>
                                </div>
                            </div>
                        </div>
                    `;
                        }
                    });
            }

            // Marquer une notification comme lue
            function markNotificationAsRead(id) {
                fetch("{{ path('app_notification_read', {id: 'ID'}) }}".replace('ID', id), {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.querySelector(`.notification-item[data-id="${id}"]`).remove();
                            const count = parseInt(notificationBadge.textContent) - 1;
                            if (count > 0) {
                                notificationBadge.textContent = count;
                            } else {
                                notificationBadge.classList.add('d-none');
                                notificationList.innerHTML = `
                        <div class="list-group-item">
                            <div class="row align-items-center">
                                <div class="col text-center text-muted py-3">
                                    <i class="fas fa-bell-slash fa-2x mb-2"></i>
                                    <p>Aucune notification</p>
                                </div>
                            </div>
                        </div>
                    `;
                            }
                        }
                    });
            }

            // Marquer toutes les notifications comme lues
            if (markAllAsRead) {
                markAllAsRead.addEventListener('click', function (e) {
                    e.preventDefault();
                    fetch("{{ path('app_notification_read_all') }}", {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                notificationBadge.classList.add('d-none');
                                notificationList.innerHTML = `
                        <div class="list-group-item">
                            <div class="row align-items-center">
                                <div class="col text-center text-muted py-3">
                                    <i class="fas fa-bell-slash fa-2x mb-2"></i>
                                    <p>Aucune notification</p>
                                </div>
                            </div>
                        </div>
                    `;
                            }
                        });
                });
            }

            // Charger les notifications au chargement de la page
            loadNotifications();

            // Recharger les notifications toutes les 30 secondes
            setInterval(loadNotifications, 30000);
            // Gestion du filtre par région
            const regionFilter = document.getElementById('region-filter');
            if (regionFilter) {
                regionFilter.addEventListener('change', function () {
                    const formData = new FormData();
                    formData.append('region_id', this.value);

                    fetch('{{ path("app_change_region") }}', {
                        method: 'POST',
                        body: formData
                    })
                        .then(response => {
                            if (response.ok) {
                                // Recharger la page pour appliquer le filtre
                                window.location.reload();
                            } else {
                                toastr.error('Erreur lors du changement de région');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                        });
                });
            }
            {% endif %}
        });

        // gestion des notifications
        document.addEventListener('DOMContentLoaded', function () {
            {% if app.user %}
            // Éléments DOM
            const notificationDropdown = document.getElementById('notificationDropdown');
            const notificationBadge = document.getElementById('notificationBadge');
            const notificationList = document.getElementById('notificationList');
            const markAllAsRead = document.getElementById('markAllAsRead');
            const notificationSettings = document.getElementById('notificationSettings');
            const filterButtons = document.querySelectorAll('.filter-btn');
            const notificationSettingsModal = new bootstrap.Modal(document.getElementById('notificationSettingsModal'));
            const saveNotificationSettings = document.getElementById('saveNotificationSettings');

            let notifications = [];
            let currentFilter = 'all';

            // Charger les notifications
            function loadNotifications() {
                fetch("{{ path('app_notification_ajax') }}")
                    .then(response => response.json())
                    .then(data => {
                        notifications = data.notifications;
                        updateNotificationBadge(data.count);
                        renderNotifications(currentFilter);
                    })
                    .catch(error => {
                        console.error('Erreur lors du chargement des notifications:', error);
                    });
            }

            // Mettre à jour le badge de notifications
            function updateNotificationBadge(count) {
                if (count > 0) {
                    notificationBadge.textContent = count > 99 ? '99+' : count;
                    notificationBadge.classList.remove('d-none');

                    // Animation pour les nouvelles notifications
                    if (count > parseInt(notificationBadge.textContent || 0)) {
                        notificationBadge.classList.add('pulse');
                        setTimeout(() => {
                            notificationBadge.classList.remove('pulse');
                        }, 1000);

                        // Notification toast pour les nouvelles notifications importantes
                        const newImportantNotifications = notifications.filter(n =>
                            !n.isRead && (n.type === 'danger' || n.type === 'warning')
                        );

                        if (newImportantNotifications.length > 0) {
                            newImportantNotifications.forEach(notif => {
                                showToastNotification(notif);
                            });
                        }
                    }
                } else {
                    notificationBadge.classList.add('d-none');
                }
            }

            // Afficher une notification toast
            function showToastNotification(notification) {
                const toast = document.createElement('div');
                toast.className = `toast align-items-center text-white bg-${notification.type} border-0`;
                toast.setAttribute('role', 'alert');
                toast.setAttribute('aria-live', 'assertive');
                toast.setAttribute('aria-atomic', 'true');
                toast.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas ${getNotificationIcon(notification.type)} me-2"></i>
                    ${notification.message}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        `;

                document.getElementById('toastContainer').appendChild(toast);
                const bsToast = new bootstrap.Toast(toast);
                bsToast.show();

                // Supprimer le toast après fermeture
                toast.addEventListener('hidden.bs.toast', function () {
                    toast.remove();
                });
            }

            // Obtenir l'icône appropriée pour le type de notification
            function getNotificationIcon(type) {
                switch (type) {
                    case 'danger': return 'fa-exclamation-circle';
                    case 'warning': return 'fa-exclamation-triangle';
                    case 'success': return 'fa-check-circle';
                    case 'info':
                    default: return 'fa-info-circle';
                }
            }

            // Rendre les notifications dans la liste
            function renderNotifications(filter = 'all') {
                if (notifications.length === 0) {
                    notificationList.innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-bell-slash fa-2x mb-2"></i>
                    <p>Aucune notification</p>
                </div>
            `;
                    return;
                }

                let filteredNotifications = notifications;
                if (filter === 'unread') {
                    filteredNotifications = notifications.filter(n => !n.isRead);
                }

                if (filteredNotifications.length === 0) {
                    notificationList.innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-bell-slash fa-2x mb-2"></i>
                    <p>Aucune notification ${filter === 'unread' ? 'non lue' : ''}</p>
                </div>
            `;
                    return;
                }

                let html = '';
                filteredNotifications.forEach(notif => {
                    const timeAgo = getTimeAgo(notif.createdAt);
                    const icon = getNotificationIcon(notif.type);

                    html += `
                <div class="list-group-item list-group-item-action ${notif.isRead ? '' : 'bg-light'} notification-item" data-id="${notif.id}">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <span class="status-dot status-dot-${notif.type} d-block"></span>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-1">${notif.message}</h6>
                                <small class="text-muted">${timeAgo}</small>
                            </div>
                            ${notif.description ? `<p class="mb-1 text-muted small">${notif.description}</p>` : ''}
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-${notif.type}"><i class="fas ${icon} me-1"></i> ${notif.category || 'Système'}</small>
                                ${notif.link ? `<a href="${notif.link}" class="btn btn-sm btn-outline-primary">Voir</a>` : ''}
                            </div>
                        </div>
                        ${!notif.isRead ? `
                        <div class="flex-shrink-0 ms-2">
                            <button class="btn btn-sm btn-icon mark-as-read" data-id="${notif.id}" title="Marquer comme lu">
                                <i class="fas fa-check"></i>
                            </button>
                        </div>
                        ` : ''}
                    </div>
                </div>
            `;
                });

                notificationList.innerHTML = html;

                // Ajouter les événements pour marquer comme lu
                document.querySelectorAll('.mark-as-read').forEach(btn => {
                    btn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        const id = this.dataset.id;
                        markNotificationAsRead(id);
                    });
                });

                // Ajouter les événements de clic sur les notifications
                document.querySelectorAll('.notification-item').forEach(item => {
                    item.addEventListener('click', function () {
                        const id = this.dataset.id;
                        const notification = notifications.find(n => n.id == id);
                        if (notification && notification.link) {
                            window.location.href = notification.link;
                        }
                        if (!notification.isRead) {
                            markNotificationAsRead(id);
                        }
                    });
                });
            }

            // Calculer le temps écoulé depuis la création
            function getTimeAgo(createdAt) {
                const now = new Date();
                const created = new Date(createdAt);
                const diffMs = now - created;
                const diffMins = Math.floor(diffMs / 60000);
                const diffHours = Math.floor(diffMs / 3600000);
                const diffDays = Math.floor(diffMs / 86400000);

                if (diffMins < 1) return 'À l\'instant';
                if (diffMins < 60) return `Il y a ${diffMins} min`;
                if (diffHours < 24) return `Il y a ${diffHours} h`;
                if (diffDays < 7) return `Il y a ${diffDays} j`;

                return created.toLocaleDateString();
            }

            // Marquer une notification comme lue
            function markNotificationAsRead(id) {
                fetch("{{ path('app_notification_read', {id: 'ID'}) }}".replace('ID', id), {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Mettre à jour localement
                            const notification = notifications.find(n => n.id == id);
                            if (notification) {
                                notification.isRead = true;
                            }

                            // Mettre à jour l'interface
                            const unreadCount = notifications.filter(n => !n.isRead).length;
                            updateNotificationBadge(unreadCount);
                            renderNotifications(currentFilter);
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                    });
            }

            // Marquer toutes les notifications comme lues
            if (markAllAsRead) {
                markAllAsRead.addEventListener('click', function (e) {
                    e.preventDefault();
                    fetch("{{ path('app_notification_read_all') }}", {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Mettre à jour localement
                                notifications.forEach(n => n.isRead = true);

                                // Mettre à jour l'interface
                                updateNotificationBadge(0);
                                renderNotifications(currentFilter);
                            }
                        })
                        .catch(error => {
                            console.error('Erreur:', error);
                        });
                });
            }

            // Filtrer les notifications
            filterButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const filter = this.dataset.filter;
                    currentFilter = filter;

                    filterButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    renderNotifications(filter);
                });
            });

            // Paramètres des notifications
            if (notificationSettings) {
                notificationSettings.addEventListener('click', function (e) {
                    e.preventDefault();
                    notificationSettingsModal.show();
                });
            }

            if (saveNotificationSettings) {
                saveNotificationSettings.addEventListener('click', function () {
                    // Enregistrer les préférences (implémentation à adapter)
                    const formData = new FormData();
                    formData.append('documents', document.getElementById('notifDocuments').checked);
                    formData.append('maintenance', document.getElementById('notifMaintenance').checked);
                    formData.append('trips', document.getElementById('notifTrips').checked);
                    formData.append('system', document.getElementById('notifSystem').checked);
                    formData.append('frequency', document.getElementById('notificationFrequency').value);

                    fetch("{{ path('app_notification_preferences_save') }}", {
                        method: 'POST',
                        body: formData
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                notificationSettingsModal.hide();
                                showToast('Préférences enregistrées avec succès', 'success');
                            }
                        })
                        .catch(error => {
                            console.error('Erreur:', error);
                            showToast('Erreur lors de l\'enregistrement', 'danger');
                        });
                });
            }

            // Fonction utilitaire pour afficher des toasts
            function showToast(message, type = 'info') {
                const toast = document.createElement('div');
                toast.className = `toast align-items-center text-white bg-${type} border-0`;
                toast.setAttribute('role', 'alert');
                toast.setAttribute('aria-live', 'assertive');
                toast.setAttribute('aria-atomic', 'true');
                toast.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">
                    ${message}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        `;

                document.getElementById('toastContainer').appendChild(toast);
                const bsToast = new bootstrap.Toast(toast);
                bsToast.show();

                toast.addEventListener('hidden.bs.toast', function () {
                    toast.remove();
                });
            }

            // Charger les notifications au chargement de la page
            loadNotifications();

            // Recharger les notifications périodiquement
            setInterval(loadNotifications, 60000); // Toutes les minutes

            // Ajouter un conteneur pour les toasts s'il n'existe pas
            if (!document.getElementById('toastContainer')) {
                const toastContainer = document.createElement('div');
                toastContainer.id = 'toastContainer';
                toastContainer.className = 'toast-container position-fixed top-0 end-0 p-3';
                toastContainer.style.zIndex = '1090';
                document.body.appendChild(toastContainer);
            }
            {% endif %}
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>

</html>