{% extends 'base.html.twig' %}

{% block title %}Calendrier des Voyages{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Calendrier des Voyages</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_voyage_new') }}" class="btn btn-primary d-none d-sm-inline-block">
                                <i class="fas fa-plus me-2"></i> Nouveau Voyage
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <form method="get" class="row g-3">
                            <div class="col-md-4">
                                <label for="affectation" class="form-label">Affectation</label>
                                <select name="affectation" id="affectation" class="form-select">
                                    <option value="">Toutes les affectations</option>
                                    {% for affectation in affectations %}
                                    <option value="{{ affectation.id }}" {{ affectationId==affectation.id ? 'selected'
                                        : '' }}>{{ affectation }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="date_debut" class="form-label">Date début</label>
                                <input type="date" class="form-control" id="date_debut" name="date_debut"
                                    value="{{ dateDebut }}">
                            </div>
                            <div class="col-md-3">
                                <label for="date_fin" class="form-label">Date fin</label>
                                <input type="date" class="form-control" id="date_fin" name="date_fin"
                                    value="{{ dateFin }}">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">&nbsp;</label>
                                <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                            </div>
                        </form>
                        {# Section des indicateurs #}
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h3 class="card-title">Indicateurs pour la période</h3>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <div class="card card-sm">
                                                    <div class="card-body">
                                                        <div class="row align-items-center">
                                                            <div class="col-auto">
                                                                <span class="bg-primary text-white avatar">
                                                                    <i class="fas fa-route"></i>
                                                                </span>
                                                            </div>
                                                            <div class="col">
                                                                <div class="font-weight-medium">
                                                                    {{ stats.total_voyages }} Voyages
                                                                </div>
                                                                <div class="text-muted">
                                                                    Total
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card card-sm">
                                                    <div class="card-body">
                                                        <div class="row align-items-center">
                                                            <div class="col-auto">
                                                                <span class="bg-green text-white avatar">
                                                                    <i class="fas fa-road"></i>
                                                                </span>
                                                            </div>
                                                            <div class="col">
                                                                <div class="font-weight-medium">
                                                                    {{ stats.total_km }} km
                                                                </div>
                                                                <div class="text-muted">
                                                                    Distance totale
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card card-sm">
                                                    <div class="card-body">
                                                        <div class="row align-items-center">
                                                            <div class="col-auto">
                                                                <span class="bg-yellow text-white avatar">
                                                                    <i class="fas fa-gas-pump"></i>
                                                                </span>
                                                            </div>
                                                            <div class="col">
                                                                <div class="font-weight-medium">
                                                                    {{ stats.total_carburant }} L
                                                                </div>
                                                                <div class="text-muted">
                                                                    Carburant consommé
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card card-sm">
                                                    <div class="card-body">
                                                        <div class="row align-items-center">
                                                            <div class="col-auto">
                                                                <span class="bg-red text-white avatar">
                                                                    <i class="fas fa-map-marker-alt"></i>
                                                                </span>
                                                            </div>
                                                            <div class="col">
                                                                <div class="font-weight-medium">
                                                                    Top destinations
                                                                </div>
                                                                <div class="text-muted">
                                                                    {% for destination, count in stats.top_destinations
                                                                    %}
                                                                    {{ destination }} ({{ count }})<br>
                                                                    {% endfor %}
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        {# Chargement par type #}
                                        {% if stats.chargement_par_type is not empty %}
                                        <div class="row mt-4">
                                            <div class="col-12">
                                                <h4>Chargement par type</h4>
                                                <div class="table-responsive">
                                                    <table class="table table-bordered">
                                                        <thead>
                                                            <tr>
                                                                <th>Type de chargement</th>
                                                                <th>Quantité</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% for type, quantite in stats.chargement_par_type %}
                                                            <tr>
                                                                <td>{{ type }}</td>
                                                                <td>{{ quantite }}</td>
                                                            </tr>
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                {% if voyagesParDate is not empty %}
                {% set dates = voyagesParDate|keys %}
                {% for i in 0..(dates|length - 1) %}
                {% if i % 3 == 0 %}
                <div class="row mb-4">
                    {% endif %}

                    <div class="col-md-4">
                        {% set date = dates[i] %}
                        {% set voyages = voyagesParDate[date] %}
                        <div class="card h-100">
                            <div class="card-header">
                                <h3 class="card-title">{{ date|date('d/m/Y') }}</h3>
                            </div>
                            <div class="card-body">
                                {% for voyage in voyages %}
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h4 class="card-title">{{ voyage.titre }}</h4>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <strong>Affectation:</strong> {{ voyage.affectation }}
                                        </div>
                                        <div class="mb-2">
                                            <strong>Convoyeur:</strong> {{ voyage.convoyeur }}
                                        </div>
                                        <div class="mb-2">
                                            <strong>Carburant:</strong> {{ voyage.quantiteCarburant }} L
                                        </div>
                                        <div class="mb-2">
                                            <strong>Chargement:</strong>
                                            {% if voyage.quantiteChargement > 0 %}
                                            {{ voyage.quantiteChargement }} ({{ voyage.typeChargement.libelle }})
                                            {% else %}
                                            À vide
                                            {% endif %}
                                        </div>
                                        <div class="mb-2">
                                            <strong>Distance totale:</strong> {{ voyage.getDistanceTotale() }} km
                                        </div>
                                        <hr>
                                        <h5>Trajets</h5>
                                        {% for voyageVehicule in voyage.voyageVehicules %}
                                        <div class="trajet mb-2">
                                            <div><strong>Destination:</strong> {{ voyageVehicule.destination.libelle }}
                                            </div>
                                            <div><strong>Distance:</strong> {{ voyageVehicule.destination.distance }} km
                                            </div>
                                            <div><strong>Commentaire:</strong> {{ voyageVehicule.commentaire }}</div>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                            <div class="btn-group btn-group-sm mt-2">
                                                {# Bouton Modifier - toujours visible #}
                                                <a href="{{ path('app_voyage_vehicule_edit', {'id': voyageVehicule.id}) }}"
                                                    class="btn btn-secondary">Modifier trajet</a>

                                                {# Bouton Supprimer - seulement si le voyage a plus d'un trajet #}
                                                {% if voyage.voyageVehicules|length > 1 %}
                                                <form method="post"
                                                    action="{{ path('app_voyage_vehicule_delete', {'id': voyageVehicule.id}) }}"
                                                    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce trajet ?');"
                                                    class="d-inline">
                                                    <input type="hidden" name="_token"
                                                        value="{{ csrf_token('delete' ~ voyageVehicule.id) }}">
                                                    <button type="submit" class="btn btn-danger">Supprimer
                                                        trajet</button>
                                                </form>
                                                {% endif %}
                                            </div>
                                            {% endif %}
                                        </div>
                                        {% if not loop.last %}
                                        <hr>{% endif %}
                                        {% endfor %}
                                    </div>
                                    <div class="card-footer">
                                        <a href="{{ path('app_voyage_show', {'id': voyage.id}) }}"
                                            class="btn btn-icon btn-sm" title="Détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_voyage_edit', {'id': voyage.id}) }}"
                                            class="btn btn-icon btn-sm" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                        <form method="post" action="{{ path('app_voyage_delete', {'id': voyage.id}) }}"
                                            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce voyage ?');"
                                            class="d-inline">
                                            <input type="hidden" name="_token"
                                                value="{{ csrf_token('delete' ~ voyage.id) }}">
                                            <button type="submit" class="btn btn-icon btn-sm text-danger"
                                                title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    {% if (i % 3 == 2) or (loop.last) %}
                </div>
                {% endif %}
                {% endfor %}
                {% else %}
                <div class="empty">
                    <p class="empty-title">Aucun voyage trouvé</p>
                </div>
                {% endif %}
            </div>
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
        <div class="row mt-4">
            <div class="col-12">
                <nav>
                    <ul class="pagination">
                        {% if page > 1 %}
                        <li class="page-item">
                            <a class="page-link"
                                href="{{ path('app_voyage_index', {affectation: affectationId, date_debut: dateDebut, date_fin: dateFin, page: page - 1}) }}">
                                Précédent
                            </a>
                        </li>
                        {% endif %}

                        {% for i in 1..totalPages %}
                        <li class="page-item {{ i == page ? 'active' : '' }}">
                            <a class="page-link"
                                href="{{ path('app_voyage_index', {affectation: affectationId, date_debut: dateDebut, date_fin: dateFin, page: i}) }}">
                                {{ i }}
                            </a>
                        </li>
                        {% endfor %}

                        {% if page < totalPages %} <li class="page-item">
                            <a class="page-link"
                                href="{{ path('app_voyage_index', {affectation: affectationId, date_debut: dateDebut, date_fin: dateFin, page: page + 1}) }}">
                                Suivant
                            </a>
                            </li>
                            {% endif %}
                    </ul>
                </nav>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}