{% extends 'base.html.twig' %}

{% block title %}Gestion des vidanges{% endblock %}

{% block stylesheets %}
{{ parent() }}
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="container-xl">
        <!-- Cartes d'insights -->
        <div class="row row-cards mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-primary text-white avatar">
                                    <i class="fas fa-oil-can"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ totalVidanges }} Vidanges
                                </div>
                                <div class="text-muted">
                                    Total des vidanges
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-green text-white avatar">
                                    <i class="fas fa-money-bill-wave"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ totalCout|number_format(0, ',', ' ') }} FCFA
                                </div>
                                <div class="text-muted">
                                    Coût total
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-blue text-white avatar">
                                    <i class="fas fa-car"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {{ vehicules|length }} Véhicules
                                </div>
                                <div class="text-muted">
                                    Disponibles
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card card-sm">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="bg-warning text-white avatar">
                                    <i class="fas fa-calendar-alt"></i>
                                </span>
                            </div>
                            <div class="col">
                                <div class="font-weight-medium">
                                    {% if prochaineVidange %}
                                    {{ prochaineVidange.prochaineVidangePrevue|date('d/m/Y') }}
                                    {% else %}
                                    Aucune
                                    {% endif %}
                                </div>
                                <div class="text-muted">
                                    Prochaine vidange
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Liste des vidanges</h3>
                        <div class="ms-auto">
                            <a href="{{ path('app_vidange_vehicule_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-2 d-none d-sm-inline-block"></i>
                                <span class="d-none d-sm-inline-block">Nouvelle vidange</span>
                                <i class="fas fa-plus d-sm-none"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        {% for message in app.flashes('success') %}
                        <div class="alert alert-success">
                            {{ message }}
                        </div>
                        {% endfor %}

                        {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">
                            {{ message }}
                        </div>
                        {% endfor %}

                        <!-- Filtre par véhicule avec Tom Select -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <form method="get" id="filterForm">
                                    <div class="input-group">
                                        <select name="vehicule" id="vehiculeSelect" class="form-select me-2"
                                            placeholder="Rechercher un véhicule...">
                                            <option value="">Tous les véhicules</option>
                                            {% for vehicule in vehicules %}
                                            <option value="{{ vehicule.id }}" {{ selectedVehicule==vehicule.id
                                                ? 'selected' : '' }}>
                                                {{ vehicule.idMarque.nomMarque }} {{ vehicule.modeleVehicule.nomModele
                                                }} ({{ vehicule.immatriculationVehicule }})
                                            </option>
                                            {% endfor %}
                                        </select>
                                        {% if selectedVehicule %}
                                        <a href="{{ path('app_vidange_vehicule_index') }}"
                                            class="btn btn-secondary mt-2">Réinitialiser</a>
                                        {% endif %}
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table id="vidangesTable" class="table table-bordered table-striped display nowrap" style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Véhicule</th>
                                        <th>Date</th>
                                        <th>Kilométrage</th>
                                        <th>Type d'huile</th>
                                        <th>Coût</th>
                                        <th>Observations</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for vidange in pagination %}
                                    <tr>
                                        <td>
                                            {{ vidange.affectation.idVehicule.idMarque.nomMarque }}
                                            {{ vidange.affectation.idVehicule.modeleVehicule.nomModele }}
                                            ({{ vidange.affectation.idVehicule.immatriculationVehicule }})
                                        </td>
                                        <td>{{ vidange.dateVidange|date('d/m/Y') }}</td>
                                        <td>{{ vidange.kilometrageVidange }} km</td>
                                        <td>{{ vidange.typeHuile ?? 'N/A' }}</td>
                                        <td>{{ vidange.cout ?? 'N/A' }} FCFA</td>
                                        <td>
                                            {% if vidange.observations %}
                                            <span title="{{ vidange.observations }}">
                                                {{ vidange.observations|length > 50 ? vidange.observations|slice(0, 50)
                                                ~ '...' : vidange.observations }}
                                            </span>
                                            {% else %}
                                            N/A
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if vidange.effectuee %}
                                            <span class="badge text-bg-success">Effectuée</span>
                                            {% else %}
                                            <span class="badge text-bg-warning">Planifiée</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_vidange_vehicule_show', {'id': vidange.id}) }}"
                                                class="btn btn-icon btn-sm" title="Détails">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_vidange_vehicule_edit', {'id': vidange.id}) }}"
                                                class="btn btn-icon btn-sm" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                            <form method="post"
                                                action="{{ path('app_vidange_vehicule_delete', {'id': vidange.id}) }}"
                                                onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette vidange ?');"
                                                class="d-inline">
                                                <input type="hidden" name="_token"
                                                    value="{{ csrf_token('delete' ~ vidange.id) }}">
                                                <button type="submit" class="btn btn-icon btn-sm text-danger"
                                                    title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Initialisation des tooltips Bootstrap
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        // Initialisation de Tom Select
        new TomSelect('#vehiculeSelect', {
            maxOptions: null,
            searchField: ['text'],
            onChange: function (value) {
                // Soumettre automatiquement le formulaire quand une sélection est faite
                document.getElementById('filterForm').submit();
            }
        });

        // Initialisation de DataTable avec les boutons d'exportation
        $('#vidangesTable').DataTable({
            dom: 'Bfrtip',
            buttons: [
                {
                    extend: 'excel',
                    text: '<i class="fas fa-file-excel"></i> Excel',
                    className: 'btn btn-success',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4, 5, 6] // Exclure la colonne Actions
                    }
                },
                {
                    extend: 'pdf',
                    text: '<i class="fas fa-file-pdf"></i> PDF',
                    className: 'btn btn-danger',
                    exportOptions: {
                        columns: [0, 1, 2, 3, 4, 5, 6] // Exclure la colonne Actions
                    }
                }
            ],
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
            },
            responsive: true,
            order: [[1, 'desc']], // Trier par date décroissante par défaut
            pageLength: 10,
            lengthMenu: [[10, 25, 50, -1], [10, 25, 50, "Tous"]]
        });
    });
</script>
{% endblock %}