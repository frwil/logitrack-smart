{% extends 'base.html.twig' %}

{% block title %}Liste des Modèles de Véhicules{% endblock %}

{% block body %}
<div class="page-body">
    <div class="row row-cards">
        <div class="col-12">
            <div class="card card-table">
                <div class="card-header">
                    <h3 class="card-title">Modèles de Véhicules</h3>
                    <div class="ms-auto">
                        <a href="{{ path('app_modele_vehicule_new') }}" class="btn btn-primary d-none d-sm-inline-block">
                            <i class="fas fa-plus me-2"></i> Nouveau Modèle
                        </a>
                    </div>
                </div>
                <div class="table-responsive">
                    <table id="modele-vehicule-table" class="table card-table table-vcenter text-nowrap datatable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nom</th>
                                <th>Marque</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for modele_vehicule in modele_vehicules %}
                            <tr>
                                <td>{{ modele_vehicule.id }}</td>
                                <td>{{ modele_vehicule.nomModele }}</td>
                                <td>{{ modele_vehicule.idMarque.nomMarque }}</td>
                                <td>
                                    <a href="{{ path('app_modele_vehicule_show', {'id': modele_vehicule.id}) }}" class="btn btn-icon btn-sm" title="Détails">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_modele_vehicule_edit', {'id': modele_vehicule.id}) }}" class="btn btn-icon btn-sm" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN') %}
                                        <form method="post" action="{{ path('app_modele_vehicule_delete', {'id': modele_vehicule.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce modèle ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ modele_vehicule.id) }}">
                                            <button type="submit" class="btn btn-icon btn-sm text-danger" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4">Aucun modèle de véhicule trouvé.</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function() {
        $('#modele-vehicule-table').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/fr-FR.json'
            }
        });
    });
</script>
{% endblock %}